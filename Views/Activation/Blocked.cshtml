<script>
(function () {
    var legacyStorageKey = 'abs_legacy_device_logical_id';
    function ensureLegacyDeviceId() {
        var input = document.getElementById('deviceId');
        if (!input) return;
        if (input.value.trim().length > 0)
            return;
        var id = '';
        try {
            id = localStorage.getItem(legacyStorageKey) || '';
            if (!id) {
                id = (typeof crypto !== 'undefined' && crypto.randomUUID) ? crypto.randomUUID()
                    : ('LEG-' + Math.random().toString(36).slice(2, 14) + '-' + Date.now().toString(36).toUpperCase());
                localStorage.setItem(legacyStorageKey, id);
            }
        } catch (e) {
            id = 'LEG-' + Math.random().toString(36).slice(2, 14) + '-' + Date.now().toString(36).toUpperCase();
        }
        input.value = id.toUpperCase();
    }
    document.addEventListener('DOMContentLoaded', function () {
        ensureLegacyDeviceId();
        if (window.absSyncActivationCookies) window.absSyncActivationCookies();
    });
})();
</script>
