<script>
(function () {
    function wireCopy(btnId, inputId, copiedTitle) {
        var btn = document.getElementById(btnId);
        var inp = document.getElementById(inputId);
        if (!btn || !inp) return;
        var origTitle = btn.getAttribute('title') || 'Copy';
        btn.addEventListener('click', function () {
            var t = (inp.value || '').trim();
            /* Seat mode: hidden can lag; display node is authoritative for what the user sees. */
            if (!t && inputId === 'deviceId') {
                var disp = document.getElementById('deviceIdDisplay');
                if (disp) t = (disp.textContent || '').trim();
            }
            if (t === '—') t = '';
            if (!t) return;
            function markDone() {
                btn.setAttribute('title', copiedTitle);
                setTimeout(function () { btn.setAttribute('title', origTitle); }, 1600);
            }
            function fallback() {
                try {
                    inp.removeAttribute('readonly');
                    inp.focus();
                    inp.select();
                    if (inp.setSelectionRange) inp.setSelectionRange(0, t.length);
                    document.execCommand('copy');
                } catch (e) { }
                finally {
                    inp.setAttribute('readonly', 'readonly');
                }
                markDone();
            }
            if (navigator.clipboard && navigator.clipboard.writeText)
                navigator.clipboard.writeText(t).then(markDone).catch(fallback);
            else
                fallback();
        });
    }
    document.addEventListener('DOMContentLoaded', function () {
        wireCopy('copyDeviceIdBtn', 'deviceId', 'Copied!');
        wireCopy('copyFingerprintBtn', 'deviceFingerprint', 'Copied!');
    });
})();
</script>
