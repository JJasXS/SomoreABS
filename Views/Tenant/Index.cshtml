@model IEnumerable<YourApp.Models.TenantBrandingVm>
@{
    ViewData["Title"] = "Tenant List";
}
<h2>Tenant List</h2>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Tenant Code</th>
            <th>Tenant Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var t in Model)
    {
        <tr>
            <td>@t.TenantCode</td>
            <td>@t.TenantName</td>
            <td>
                <a asp-action="Details" asp-route-id="@t.TenantCode" class="btn btn-sm btn-info">Details</a>
            </td>
        </tr>
    }
    </tbody>
</table>
