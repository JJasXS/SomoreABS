
@model YourApp.Models.TenantBrandingVm

@{
    ViewData["Title"] = "Home";
    var logoVirtualPath = string.IsNullOrWhiteSpace(Model?.HeaderLogoUrl)
        ? "~/images/somore_logo3.png"
        : Model!.HeaderLogoUrl!.Trim();
}

<div class="flex-grow-1 d-flex align-items-center justify-content-center w-100 px-2 py-3">
    <div class="container" style="max-width: 1000px;">
        <div class="card shadow" style="border-radius: 12px;">
            <div class="card-body p-4 text-center">

                <img src="@Url.Content(logoVirtualPath)"
                     alt="@(string.IsNullOrWhiteSpace(Model?.TenantName) ? "Logo" : Model!.TenantName.Trim())"
                     class="mb-3"
                     style="max-height: 160px; width: auto; max-width: 20%; object-fit: contain;" />

                <h4 class="display-6 mb-2" style="font-weight: 500, font-size: 200px;">
                    @(string.IsNullOrWhiteSpace(Model?.HeaderText1) ? "Appointment Management System" : Model!.HeaderText1)
                </h4>

                <p class="lead mb-3" style="opacity: .85;">
                    @(string.IsNullOrWhiteSpace(Model?.HeaderText2) ? "Make appointment bookings here!" : Model!.HeaderText2)
                </p>

                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <a class="btn btn-primary btn-lg px-4 py-2" href="@Url.Action("Login", "Account")">
                        Login with OTP
                    </a>
                </div>

                <hr class="my-3" />

                <div class="text-muted" style="font-size: 13px;">
                    <div><b>Managed by ProAcc System Consulting.</b></div>
                    <div style="opacity:.8;">V 1.2</div>
                </div>

            </div>
        </div>
    </div>
</div>
