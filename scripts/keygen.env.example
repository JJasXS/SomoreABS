# Copy this file to `.env` next to this script or in the repo root, then fill in values.
# The file `.env` is gitignored — never commit real tokens.
#
# Where to get values (Keygen / keygen.sh):
# - KEYGEN_ACCOUNT_ID: Keygen app → your account. Shown in Settings and in API URLs as
#   .../accounts/<this-id>/...
# - KEYGEN_API_TOKEN: Keygen app → Settings → API tokens (or Environment/Product token).
#   Use a token that is allowed to create machines for your product.
#
# Windows PowerShell (current session):
#   $env:KEYGEN_ACCOUNT_ID = "your-account-id"
#   $env:KEYGEN_API_TOKEN = "your-token"
#   python keygen_license_activate.py
#
# Optional:
# KEYGEN_API_BASE=https://api.keygen.sh/v1
# KEYGEN_PREFER_VALIDATE_KEY_ONLY=false

