@{
    ViewData["Title"] = "Customer History";
    string fromDate = (string)(ViewBag.FromDate ?? "");
    string toDate = (string)(ViewBag.ToDate ?? "");
}

<!-- Back Button beside heading -->
<div style="position:relative;margin-top:32px;margin-bottom:16px;">
    <a href="/Calendar/Index" style="position:absolute;left:18px;top:50%;transform:translateY(-50%);display:flex;align-items:center;background:#007bff;border-radius:8px;padding:0 12px;height:36px;color:#fff;font-size:18px;box-shadow:0 2px 8px rgba(0,0,0,0.12);text-decoration:none;font-weight:600;">
        <span style="font-size:22px;margin-right:8px;">&#8592;</span> Back
    </a>
    <div style="text-align:center;">
        <h2 style="margin:0;">Customer History</h2>
    </div>
</div>

<div style="padding-left: 40px; padding-right: 40px;">
    <!-- Filter Bar -->
    <form method="get" asp-action="History" style="margin-bottom: 24px; display: flex; gap: 12px; align-items: center; justify-content: center; flex-wrap: wrap;">
        <label for="customerCode" style="font-weight:600;">Customer:</label>
        @await Html.PartialAsync("_CustomerDropdownPartial", ViewBag.Customers as IEnumerable<YourApp.Models.AR_CUSTOMER>)
        <label for="fromDate" style="font-weight:600; margin-left:8px;">From:</label>
        <input type="date" id="fromDate" name="fromDate" class="form-control" style="width:170px;" value="@fromDate" />
        <label for="toDate" style="font-weight:600;">To:</label>
        <input type="date" id="toDate" name="toDate" class="form-control" style="width:170px;" value="@toDate" />
        <button type="submit" class="btn btn-primary">Filter</button>
    </form>

    <!-- 3-Column Appointment Status Layout -->
    <div style="display: flex; gap: 18px;">
    <div style="flex:1; background:#f8fff8; border-radius:10px; padding:16px; min-width:220px; position:relative;">
        <h4 style="color:#28a745; text-align:center; margin:0;">FULFILLED</h4>
        @if ((ViewBag.Fulfilled as List<YourApp.Models.Appointment>)?.Count > 0)
        {
            <ul style="padding-left:0; list-style:none;">
            @foreach (var appt in (List<YourApp.Models.Appointment>)ViewBag.Fulfilled)
            {
                <li style="margin-bottom:10px; border-bottom:1px solid #e0e0e0; padding-bottom:8px; display:flex; align-items:center; justify-content:space-between;">
                    <div>
                        <b>Code:</b> @appt.ApptId<br />
                        <b>Title:</b> @appt.Title<br />
                        <b>Date/Time:</b> @appt.ApptStart.ToString("yyyy-MM-dd HH:mm")<br />
                        <!-- Customer line removed as requested -->
                        <b>Agent:</b> @(appt.AgentName?.Split("??")[0].Trim() ?? appt.AgentCode)<br />
                        @if (!string.IsNullOrWhiteSpace(appt.Notes)) { <div style="font-size:85%;color:#888;">@appt.Notes</div> }
                    </div>
                    @{
                        var logIdMap = ViewBag.AppointmentLogIds as Dictionary<long, long>;
                        long logId = 0;
                        if (logIdMap != null && logIdMap.ContainsKey(appt.ApptId))
                        {
                            logId = logIdMap[appt.ApptId];
                        }
                    }
                    @if (logId > 0)
                    {
                        <a href="@Url.Action("PrintPdfByLog", "Appointment", new { logId = logId })" target="_blank" class="btn btn-outline-success btn-sm" title="Print this appointment">
                            <span class="bi bi-printer" style="margin-right:4px;"></span>Print
                        </a>
                    }
                </li>
            }
            </ul>
        }
        else
        {
            <div style="color:#888; text-align:center;">No data</div>
        }
    </div>
    <div style="flex:1; background:#f8f9ff; border-radius:10px; padding:16px; min-width:220px;">
        <h4 style="color:#007bff; text-align:center;">BOOKED</h4>
        @if ((ViewBag.Booked as List<YourApp.Models.Appointment>)?.Count > 0)
        {
            <ul style="padding-left:0; list-style:none;">
            @foreach (var appt in (List<YourApp.Models.Appointment>)ViewBag.Booked)
            {
                <li style="margin-bottom:10px; border-bottom:1px solid #e0e0e0; padding-bottom:8px;">
                    <b>Code:</b> @appt.ApptId<br />
                    <b>Title:</b> @appt.Title<br />
                    <b>Date/Time:</b> @appt.ApptStart.ToString("yyyy-MM-dd HH:mm")<br />
                    <!-- Customer line removed as requested -->
                    <b>Agent:</b> @(appt.AgentName?.Split("??")[0].Trim() ?? appt.AgentCode)<br />
                    @if (!string.IsNullOrWhiteSpace(appt.Notes)) { <div style="font-size:85%;color:#888;">@appt.Notes</div> }
                </li>
            }
            </ul>
        }
        else
        {
            <div style="color:#888; text-align:center;">No data</div>
        }
    </div>
    <div style="flex:1; background:#fff8f8; border-radius:10px; padding:16px; min-width:220px;">
        <h4 style="color:#dc3545; text-align:center;">CANCELLED</h4>
        @if ((ViewBag.Cancelled as List<YourApp.Models.Appointment>)?.Count > 0)
        {
            <ul style="padding-left:0; list-style:none;">
            @foreach (var appt in (List<YourApp.Models.Appointment>)ViewBag.Cancelled)
            {
                <li style="margin-bottom:10px; border-bottom:1px solid #e0e0e0; padding-bottom:8px;">
                    <b>Code:</b> @appt.ApptId<br />
                    <b>Title:</b> @appt.Title<br />
                    <b>Date/Time:</b> @appt.ApptStart.ToString("yyyy-MM-dd HH:mm")<br />
                    <!-- Customer line removed as requested -->
                    <b>Agent:</b> @(appt.AgentName?.Split("??")[0].Trim() ?? appt.AgentCode)<br />
                    @if (!string.IsNullOrWhiteSpace(appt.Notes)) { <div style="font-size:85%;color:#888;">@appt.Notes</div> }
                </li>
            }
            </ul>
        }
        else
        {
            <div style="color:#888; text-align:center;">No data</div>
        }
    </div>
    </div>
</div>
