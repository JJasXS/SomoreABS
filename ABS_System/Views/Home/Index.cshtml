
@model YourApp.Models.TenantBrandingVm

@{
    ViewData["Title"] = "Home";
}

<div class="flex-grow-1 d-flex align-items-center justify-content-center w-100 px-2 py-3">
<div class="container" style="max-width: 1000px;">
    <div class="card shadow" style="border-radius: 9px;">
        <div class="card-body p-3 p-md-4 text-center">

            <img src="~/images/somore_logo3.png"
                 alt="@(string.IsNullOrWhiteSpace(Model?.TenantName) ? "Logo" : Model!.TenantName.Trim())"
                 class="mb-2"
                 style="max-height: 133px; width: auto; max-width: 100%; object-fit: contain;" />


            <h1 class="display-6 mb-2" style="font-weight: 500;">
                @(string.IsNullOrWhiteSpace(Model?.HeaderText1) ? "Welcome" : Model!.HeaderText1)
            </h1>

            <p class="lead fs-5 mb-3" style="opacity: .85;">
                @(string.IsNullOrWhiteSpace(Model?.HeaderText2) ? "Make appointment bookings here!" : Model!.HeaderText2)
            </p>

            <div class="d-flex justify-content-center gap-2 flex-wrap">
                <a class="btn btn-primary btn-lg px-3 py-2" href="@Url.Action("Login", "Account")">
                    Login with OTP
                </a>
            </div>

            <hr class="my-3" />

            <div class="text-muted" style="font-size: 10px;">
                <div><b>Managed by ProAcc System Consulting.</b></div>
                <div style="opacity:.8;">V 1.1</div>
            </div>

        </div>
    </div>
</div>
</div>
