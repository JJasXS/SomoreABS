@model YourApp.Models.TenantBrandingVm

@{
    ViewData["Title"] = "Home";

    var titleText = string.IsNullOrWhiteSpace(Model?.HeaderText1)
        ? "Welcome"
        : Model!.HeaderText1;

    var subText = string.IsNullOrWhiteSpace(Model?.HeaderText2)
        ? "Appointment Booking System"
        : Model!.HeaderText2;

    var companyName = string.IsNullOrWhiteSpace(Model?.TenantName)
        ? "Managed by ProAcc System Consulting. "
        : Model!.TenantName;
}

<div class="container" style="max-width: 980px; margin-top: 8px; margin-bottom: 8px;">
    <div class="card shadow-sm" style="border-radius: 10px;">
        <div class="card-body p-2 p-md-3 text-center">

            <h1 class="display-6 mb-2" style="font-weight: 700;">
                @titleText
            </h1>

            <p class="lead mb-2" style="opacity: .85;">
                @subText
            </p>

            <div class="d-flex justify-content-center gap-2 flex-wrap">
                <a class="btn btn-primary px-3" href="@Url.Action("Login", "Account")">
                    Login with OTP
                </a>
            </div>

            <hr class="my-3" />

            <div class="text-muted" style="font-size: 12px;">
                <div><b>@companyName</b></div>
                <div style="opacity:.8;">V 1.0</div>
            </div>

        </div>
    </div>
</div>
