@await Html.PartialAsync("~/Views/Shared/LayoutPartials/_Header.cshtml")

@model List<YourApp.Controllers.CalendarEventVm>
@using System.Linq

@{
    ViewData["Title"] = "Calendar";

    int year = (int)ViewBag.Year;
    int month = (int)ViewBag.Month;

    DateTime firstDay = (DateTime)ViewBag.FirstDay;
    int daysInMonth = DateTime.DaysInMonth(year, month);

    // Sunday=0 ... Saturday=6
    int startOffset = (int)firstDay.DayOfWeek;

    // ✅ Pick-date mode: show + in each day only when pickDate=1
    bool pickDate = false;
    if (Context.Request.Query.ContainsKey("pickDate"))
    {
        var v = Context.Request.Query["pickDate"].ToString();
        pickDate = (v == "1" || v.Equals("true", StringComparison.OrdinalIgnoreCase) || v.Equals("y", StringComparison.OrdinalIgnoreCase));
    }

    // Month dropdown source
    var monthItems = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames
        .Take(12)
        .Select((name, idx) => new { Text = name, Value = idx + 1 })
        .ToList();

    // Year dropdown range
    int startYear = DateTime.Today.Year - 5;
    int endYear = DateTime.Today.Year + 5;

    // ✅ Safe cast
    var monthAppointments = ViewBag.MonthAppointments as List<YourApp.Models.Appointment>
                            ?? new List<YourApp.Models.Appointment>();

    // ✅ Safe cast dictionaries (IMPORTANT!)
    var agentColors = ViewBag.AgentColors as Dictionary<string, string>
                      ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    var agentNames = ViewBag.AgentNames as Dictionary<string, string>
                     ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    var customerNames = ViewBag.CustomerNames as Dictionary<string, string>
                        ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
}

<link rel="stylesheet" href="~/css/calendar.css" />

<h2 class="calendar-title">
    Calendar -
    <span id="calendarMonthLabel"
          class="calendar-month-click"
          onclick="showMonthModal('@year', '@month')">
        @firstDay.ToString("MMMM yyyy")
    </span>
</h2>

<!-- Modal Overlay -->
<div id="modalOverlay" class="modal-overlay" style="display:none;"></div>

<!-- ✅ Month Modal -->
<div id="monthAppointmentsModal" class="custom-modal" style="display:none;">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 id="monthAppointmentsModalLabel">
                Appointments for <span id="modalMonthLabel"></span>
            </h5>
            <button type="button" id="closeMonthModal" class="modal-close">&times;</button>
        </div>
        <div class="custom-modal-body">
            <div id="month-appointments-list" class="appt-card-list"></div>
        </div>
    </div>
</div>

<!-- ✅ Day Modal -->
<div id="dayAppointmentsModal" class="custom-modal" style="display:none;">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 id="dayAppointmentsModalLabel">
                Appointments for <span id="modalDayLabel"></span>
            </h5>
            <button type="button" id="closeDayModal" class="modal-close">&times;</button>
        </div>
        <div class="custom-modal-body">
            <a id="add-appointment-btn" class="custom-modal-btn" href="#">+ New Booking</a>
            <div id="day-appointments-list" class="appt-card-list"></div>
        </div>
    </div>
</div>
<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0,0,0,0.5);
        z-index: 1000;
        display: none;
    }
    .custom-modal {
        z-index: 1001;
    }
</style>

<!-- ✅ Top row: Search (left) + Nav buttons (right) -->
<div class="calendar-toolbar">
    <form method="get" action="@Url.Action("Index")" class="calendar-search-form">
        <select name="month" class="form-select calendar-month-select">
            @foreach (var mm in monthItems)
            {
                <option value="@mm.Value" selected="@(mm.Value == month ? "selected" : null)">@mm.Text</option>
            }
        </select>

        <select name="year" class="form-select calendar-year-select">
            @for (int y = startYear; y <= endYear; y++)
            {
                <option value="@y" selected="@(y == year ? "selected" : null)">@y</option>
            }
        </select>

        @if (pickDate)
        {
            <input type="hidden" name="pickDate" value="1" />
        }

        <button type="submit" class="btn btn-primary">Search</button>
    </form>

    <div class="calendar-nav-actions">
        <a class="btn btn-secondary"
           href="@Url.Action("Index", new { year = firstDay.AddMonths(-1).Year, month = firstDay.AddMonths(-1).Month, pickDate = pickDate ? 1 : (int?)null })">
            &lt; Prev
        </a>

        <a class="btn btn-secondary"
           href="@Url.Action("Index", new { year = DateTime.Today.Year, month = DateTime.Today.Month, pickDate = pickDate ? 1 : (int?)null })">
            Today
        </a>

        <a class="btn btn-secondary"
           href="@Url.Action("Index", new { year = firstDay.AddMonths(1).Year, month = firstDay.AddMonths(1).Month, pickDate = pickDate ? 1 : (int?)null })">
            Next &gt;
        </a>
    </div>
</div>

<table class="table table-bordered calendar-table">
    <thead>
        <tr>
            <th>Sun</th><th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th>
        </tr>
    </thead>
    <tbody>
        @{
            int day = 1;
            int cell = 0;

            while (day <= daysInMonth)
            {
                <tr>
                    @for (int i = 0; i < 7; i++)
                    {
                        if (cell < startOffset || day > daysInMonth)
                        {
                            <td class="calendar-cell calendar-cell-empty"></td>
                        }
                        else
                        {
                            var date = new DateTime(year, month, day);
                            var appts = monthAppointments.Where(a => a.ApptStart.Date == date.Date).ToList();

                            <td class="calendar-cell calendar-cell-day"
                                data-date="@date.ToString("yyyy-MM-dd")"
                                tabindex="0"
                                role="button"
                                aria-label="Show appointments for @date.ToString("yyyy-MM-dd")">

                                <div class="calendar-cell-header">
                                    <strong class="day-number">@day</strong>
                                </div>

                                @if (appts.Count > 0)
                                {
                                    <div class="scrollable-appt-list appt-card-list in-cell">
                                        @foreach (var appt in appts)
                                        {
                                            var agentCode = (appt.AgentCode ?? "").Trim();

                                            string cardColor = null;
                                            if (!string.IsNullOrEmpty(agentCode) && agentColors.TryGetValue(agentCode, out var c))
                                            {
                                                cardColor = c;
                                            }

                                                <div class="appt-card in-cell"
                                                    style="@(cardColor != null ? $"background-color:{cardColor} !important; display:flex !important; align-items:center !important; min-height:22px !important; padding:2px 8px !important;" : "display:flex !important; align-items:center !important; min-height:22px !important; padding:2px 8px !important;")">
                                                <span class="appt-title">@(
                                                    string.IsNullOrWhiteSpace(appt.Title)
                                                        ? ""
                                                        : System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(appt.Title.ToLower())
                                                )</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </td>

                            day++;
                        }

                        cell++;
                    }
                </tr>
            }
        }
    </tbody>
</table>

@section Scripts {
    <script>
        // ✅ Data from backend
        var allAppointments = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthAppointments));
        window.agentNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AgentNames ?? new Dictionary<string, string>()));
        window.customerNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CustomerNames ?? new Dictionary<string, string>()));
        window.agentColors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AgentColors ?? new Dictionary<string, string>()));

        function buildApptCard(appt) {
            var when = '';
            var timeOnly = '';
            if (appt.ApptStart) {
                when = appt.ApptStart.replace('T', ' ').substring(0, 16);
                timeOnly = appt.ApptStart.replace('T', ' ').substring(11, 16);
            }

            var cust = (window.customerNames && window.customerNames[appt.CustomerCode]) ? window.customerNames[appt.CustomerCode] : (appt.CustomerCode || '');
            var agent = (window.agentNames && window.agentNames[appt.AgentCode]) ? window.agentNames[appt.AgentCode] : (appt.AgentCode || '');
            var cardColor = (window.agentColors && window.agentColors[appt.AgentCode]) ? window.agentColors[appt.AgentCode] : null;
            var style = cardColor ? ' style="background-color: ' + cardColor + ' !important;"' : '';

            return (
                '<div class="appt-card modal-card"' + style + '>' +
                    '<div class="appt-top">' +
                        '<div class="appt-title">' + (appt.Title || '') + '</div>' +
                        '<div class="appt-time">' + (timeOnly || '') + '</div>' +
                    '</div>' +
                    '<div class="appt-meta">' +
                        '<div class="appt-meta-line"><span class="appt-meta-label">When:</span> <span class="appt-meta-value">' + when + '</span></div>' +
                        '<div class="appt-meta-line"><span class="appt-meta-label">Cust:</span> <span class="appt-meta-value">' + cust + '</span></div>' +
                        '<div class="appt-meta-line"><span class="appt-meta-label">Agent:</span> <span class="appt-meta-value">' + agent + '</span></div>' +
                        '<div class="appt-actions" style="margin-top:6px; display:flex; gap:6px; align-items:center;">' +
                            '<a href="/Appointment/Edit/' + appt.ApptId + '" class="btn btn-sm btn-primary">Edit</a>' +
                            '<a href="/Appointment/Delete/' + appt.ApptId + '" class="btn btn-sm btn-danger" onclick="return confirm(\'Are you sure you want to delete this appointment?\');">Delete</a>' +
                        '</div>' +
                    '</div>' +
                '</div>'
            );
        }

        function showMonthModal(year, month) {
            var modalEl = document.getElementById('monthAppointmentsModal');
            var label = document.getElementById('modalMonthLabel');
            var list = document.getElementById('month-appointments-list');
            var overlay = document.getElementById('modalOverlay');

            var monthStr = year + '-' + (month.toString().length === 1 ? '0' + month : month);
            label.textContent = monthStr;
            list.innerHTML = '';

            var appts = (allAppointments || []).filter(function (a) {
                return a.ApptStart && a.ApptStart.startsWith(monthStr);
            });

            if (appts.length === 0) {
                list.innerHTML = '<div class="appt-empty">No appointments.</div>';
            } else {
                appts.sort(function (a, b) {
                    return (a.ApptStart || '').localeCompare(b.ApptStart || '');
                });

                var html = '';
                appts.forEach(function (appt) {
                    html += buildApptCard(appt);
                });
                list.innerHTML = html;
            }

            overlay.style.display = 'block';
            modalEl.style.display = 'block';
        }

        function showDayModal(date) {
            var modalEl = document.getElementById('dayAppointmentsModal');
            var label = document.getElementById('modalDayLabel');
            var list = document.getElementById('day-appointments-list');
            var addBtn = document.getElementById('add-appointment-btn');
            var overlay = document.getElementById('modalOverlay');

            // Format date as '1 January 2026'
            try {
                var d = new Date(date);
                if (!isNaN(d.getTime())) {
                    var day = d.getDate();
                    var month = d.toLocaleString('default', { month: 'long' });
                    var year = d.getFullYear();
                    label.textContent = day + ' ' + month + ' ' + year;
                } else {
                    label.textContent = date;
                }
            } catch (e) {
                label.textContent = date;
            }
            addBtn.href = '/Appointment/Create?apptStart=' + date + 'T09:00';

            list.innerHTML = '';

            var appts = (allAppointments || []).filter(function (a) {
                return a.ApptStart && a.ApptStart.startsWith(date);
            });

            if (appts.length === 0) {
                list.innerHTML = '<div class="appt-empty">No appointments.</div>';
            } else {
                appts.sort(function (a, b) {
                    return (a.ApptStart || '').localeCompare(b.ApptStart || '');
                });

                var html = '';
                appts.forEach(function (appt) {
                    html += buildApptCard(appt);
                });
                list.innerHTML = html;
            }

            overlay.style.display = 'block';
            modalEl.style.display = 'block';
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.calendar-cell-day').forEach(function (cell) {
                cell.addEventListener('click', function (e) {
                    e.stopPropagation();
                    showDayModal(cell.getAttribute('data-date'));
                });

                cell.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        showDayModal(cell.getAttribute('data-date'));
                    }
                });
            });

            function closeModals() {
                document.getElementById('dayAppointmentsModal').style.display = 'none';
                document.getElementById('monthAppointmentsModal').style.display = 'none';
                document.getElementById('modalOverlay').style.display = 'none';
            }

            document.getElementById('closeDayModal').addEventListener('click', closeModals);
            document.getElementById('closeMonthModal').addEventListener('click', closeModals);

            document.getElementById('modalOverlay').addEventListener('click', closeModals);
            document.getElementById('modalOverlay').addEventListener('touchstart', closeModals);
            // Prevent modal click from closing
            document.querySelectorAll('.custom-modal-content').forEach(function (modalContent) {
                modalContent.addEventListener('mousedown', function (e) {
                    e.stopPropagation();
                });
                modalContent.addEventListener('touchstart', function (e) {
                    e.stopPropagation();
                });
            });
        });
    </script>
}

@await Html.PartialAsync("~/Views/Shared/LayoutPartials/_Footer.cshtml")
