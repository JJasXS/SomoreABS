
@model List<YourApp.Controllers.CalendarEventVm>
@using System.Linq
@using System.Collections.Generic

@{
    ViewData["Title"] = "Calendar";

    int year = (int)ViewBag.Year;
    int month = (int)ViewBag.Month;

    DateTime firstDay = (DateTime)ViewBag.FirstDay;
    int daysInMonth = DateTime.DaysInMonth(year, month);

    int startOffset = (int)firstDay.DayOfWeek;

    bool pickDate = false;
    if (Context.Request.Query.ContainsKey("pickDate"))
    {
        var v = Context.Request.Query["pickDate"].ToString();
        pickDate = (v == "1" || v.Equals("true", StringComparison.OrdinalIgnoreCase) || v.Equals("y", StringComparison.OrdinalIgnoreCase));
    }

    var monthItems = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames
        .Take(12)
        .Select((name, idx) => new { Text = name, Value = idx + 1 })
        .ToList();

    int startYear = DateTime.Today.Year - 5;
    int endYear = DateTime.Today.Year + 5;

    var monthAppointments = ViewBag.MonthAppointments as List<YourApp.Models.Appointment>
                            ?? new List<YourApp.Models.Appointment>();

    var agentColors = ViewBag.AgentColors as Dictionary<string, string>
                      ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    var agentNames = ViewBag.AgentNames as Dictionary<string, string>
                     ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    var customerNames = ViewBag.CustomerNames as Dictionary<string, string>
                        ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
}

<link rel="stylesheet" href="~/css/calendar.css" />
<div class="calendar-shell">

<h2 class="calendar-title">
    Calendar -
    <span id="calendarMonthLabel"
          class="calendar-month-click"
          onclick="showMonthModal('@year', '@month')">
        @firstDay.ToString("MMMM yyyy")
    </span>
</h2>

<!-- ✅ Anti-forgery token for AJAX -->
<form id="antiForgeryForm" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div id="modalOverlay" class="modal-overlay" style="display:none;"></div>

<div id="monthAppointmentsModal" class="custom-modal" style="display:none;">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 id="monthAppointmentsModalLabel">
                Appointments for <span id="modalMonthLabel"></span>
            </h5>
            <button type="button" id="closeMonthModal" class="modal-close">&times;</button>
        </div>
        <div class="custom-modal-body">
            <div id="month-appointments-list" class="appt-card-list"></div>
        </div>
    </div>
</div>

<div id="dayAppointmentsModal" class="custom-modal" style="display:none;">
    <div class="custom-modal-content">
        <div class="custom-modal-header">
            <h5 id="dayAppointmentsModalLabel">
                Appointments for <span id="modalDayLabel"></span>
            </h5>
            <button type="button" id="closeDayModal" class="modal-close">&times;</button>
        </div>
        <div class="custom-modal-body">
            <a id="add-appointment-btn" class="custom-modal-btn" href="#">+ New Booking</a>
            <div id="day-appointments-list" class="appt-card-list"></div>
        </div>
    </div>
</div>

<!-- ✅ Confirm Delete Modal (custom, no browser "xxx says") -->
<div id="confirmDeleteModal" class="custom-modal" style="display:none;">
    <div class="custom-modal-content" style="max-width:420px;">
        <div class="custom-modal-header">
            <h5>Confirm Delete</h5>
            <button type="button" id="closeConfirmDeleteModal" class="modal-close">&times;</button>
        </div>

        <div class="custom-modal-body">
            <div style="margin-bottom:12px;">
                Are you sure you want to delete this appointment?
            </div>

            <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:10px;">
                <button type="button" id="btnDeleteCancel" class="btn btn-secondary">Cancel</button>
                <button type="button" id="btnDeleteYes" class="btn btn-danger">Yes, Delete</button>
            </div>
        </div>
    </div>
</div>

<style>
/* ================================
   ✅ Full-width (stretch) calendar
   ================================ */

/* 1) Make the outer wrapper stretch the page */
.calendar-shell{
  width: 100% !important;     /* ✅ stretch */
  max-width: none !important; /* ✅ remove limit */
  margin: 0 !important;       /* ✅ no centering gap */
  background: #fff;
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: 14px;
  padding: 14px;
  box-shadow: 0 2px 14px rgba(0,0,0,0.06);
}

/* 2) Make the toolbar stretch too */
.calendar-shell .calendar-toolbar{
  width: 100% !important;
  max-width: none !important;
  margin: 0 0 12px 0 !important;
}

/* 3) IMPORTANT: make the calendar table stretch */
.calendar-shell .calendar-table{
  width: 100% !important;     /* ✅ stretch full width */
  margin: 0 !important;
  table-layout: fixed;        /* ✅ equal width columns */
}

/* 4) Slightly tighter cells (optional) */
.calendar-shell .calendar-table th,
.calendar-shell .calendar-table td{
  padding: 6px !important;
  vertical-align: top;
}

/* 5) Prevent long titles from breaking layout */
.calendar-shell .appt-card.in-cell .appt-title{
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 6) Optional: reduce the appt list height so cells stay tidy */
.calendar-shell .scrollable-appt-list{
  max-height: 86px;
}
</style>

<div class="calendar-toolbar">
    <form method="get" action="@Url.Action("Index")" class="calendar-search-form">
        <select name="month" class="form-select calendar-month-select">
            @foreach (var mm in monthItems)
            {
                <option value="@mm.Value" selected="@(mm.Value == month ? "selected" : null)">@mm.Text</option>
            }
        </select>

        <select name="year" class="form-select calendar-year-select">
            @for (int y = startYear; y <= endYear; y++)
            {
                <option value="@y" selected="@(y == year ? "selected" : null)">@y</option>
            }
        </select>

        @if (pickDate)
        {
            <input type="hidden" name="pickDate" value="1" />
        }

        <button type="submit" class="btn btn-primary">Search</button>
    </form>

    <div class="calendar-nav-actions">
        <a class="btn btn-secondary"
           href="@Url.Action("Index", new { year = firstDay.AddMonths(-1).Year, month = firstDay.AddMonths(-1).Month, pickDate = pickDate ? 1 : (int?)null })">
            &lt; Prev
        </a>

        <a class="btn btn-secondary"
           href="@Url.Action("Index", new { year = DateTime.Today.Year, month = DateTime.Today.Month, pickDate = pickDate ? 1 : (int?)null })">
            Today
        </a>

        <a class="btn btn-secondary"
           href="@Url.Action("Index", new { year = firstDay.AddMonths(1).Year, month = firstDay.AddMonths(1).Month, pickDate = pickDate ? 1 : (int?)null })">
            Next &gt;
        </a>
    </div>
</div>

<table class="table table-bordered calendar-table">
    <thead>
        <tr>
            <th>Sun</th><th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th>
        </tr>
    </thead>
    <tbody>
        @{
            int day = 1;
            int cell = 0;

            while (day <= daysInMonth)
            {
                <tr>
                    @for (int i = 0; i < 7; i++)
                    {
                        if (cell < startOffset || day > daysInMonth)
                        {
                            <td class="calendar-cell calendar-cell-empty"></td>
                        }
                        else
                        {
                            var date = new DateTime(year, month, day);
                            var appts = monthAppointments.Where(a => a.ApptStart.Date == date.Date).ToList();

                            <td class="calendar-cell calendar-cell-day"
                                data-date="@date.ToString("yyyy-MM-dd")"
                                tabindex="0"
                                role="button"
                                aria-label="Show appointments for @date.ToString("yyyy-MM-dd")">

                                <div class="calendar-cell-header">
                                    <strong class="day-number">@day</strong>
                                </div>

                                @if (appts.Count > 0)
                                {
                                    <div class="scrollable-appt-list appt-card-list in-cell">
                                        @foreach (var appt in appts)
                                        {
                                            var agentCode = (appt.AgentCode ?? "").Trim();
                                            string cardColor = null;

                                            if (!string.IsNullOrEmpty(agentCode) && agentColors.TryGetValue(agentCode, out var c))
                                                cardColor = c;

                                            var style = "display:flex !important; align-items:center !important; min-height:20px !important; padding:2px 8px !important;";
                                            if (!string.IsNullOrEmpty(cardColor))
                                                style = $"background-color:{cardColor} !important; " + style;

                                            var statusUp = (appt.Status ?? "").Trim().ToUpperInvariant();
                                            var isDone = (statusUp == "FULFILLED" || statusUp == "DONE" || statusUp == "COMPLETED");
                                            var doneClass = isDone ? " is-fulfilled" : "";
                                            var rawTitle = (appt.Title ?? "").Trim();
                                            var titleCased = string.IsNullOrWhiteSpace(rawTitle)
                                                ? rawTitle
                                                : System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(rawTitle.ToLower());

                                            <div class="appt-card in-cell@doneClass"
                                                 data-appt-id="@appt.ApptId"
                                                 data-status="@statusUp"
                                                 style="@style">
                                                <span class="appt-title" style="@(isDone ? "opacity:0.45; font-weight:500;" : "")">
                                                    @titleCased
                                                </span>
                                            </div>
                                        }
                                    </div>
                                }
                            </td>

                            day++;
                        }

                        cell++;
                    }
                </tr>
            }
        }
    </tbody>
</table>
</div>


@section Scripts {
<script>
  // ===== Data injected from Razor =====
  var allAppointments = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthAppointments));
  window.agentNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AgentNames ?? new Dictionary<string, string>()));
  window.customerNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CustomerNames ?? new Dictionary<string, string>()));
  window.agentColors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AgentColors ?? new Dictionary<string, string>()));

  // ✅ services per appointment + service names
  window.apptServices = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ApptServices ?? new Dictionary<long, List<string>>()));
  window.serviceNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ServiceNames ?? new Dictionary<string, string>()));

  function getAntiForgeryToken() {
    var el = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
    return el ? el.value : '';
  }

  function escHtml(s) {
    return (s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function toTitleCase(s) {
    s = (s || '').toString().trim().toLowerCase();
    if (!s) return s;
    return s.replace(/(^|[\s-])([a-z])/g, function (_, p1, p2) { return p1 + p2.toUpperCase(); });
  }

  function isFulfilled(appt) {
    var status = (appt.Status || '').toString().trim().toUpperCase();
    return status === 'FULFILLED' || status === 'DONE' || status === 'COMPLETED';
  }

  function cssEscape(v) {
    if (window.CSS && typeof window.CSS.escape === 'function') return window.CSS.escape(String(v));
    return String(v).replace(/"/g, '\\"');
  }

  // ====== AJAX DELETE CONFIRM ======
  var pendingDeleteId = null;

  function openConfirmDeleteModal(apptId) {
    pendingDeleteId = apptId || null;
    var overlay = document.getElementById('modalOverlay');
    var m = document.getElementById('confirmDeleteModal');
    if (overlay) overlay.style.display = 'block';
    if (m) m.style.display = 'block';
  }

  function closeConfirmDeleteModal() {
    pendingDeleteId = null;
    var m = document.getElementById('confirmDeleteModal');
    if (m) m.style.display = 'none';

    var dayOpen = document.getElementById('dayAppointmentsModal')?.style.display === 'block';
    var monthOpen = document.getElementById('monthAppointmentsModal')?.style.display === 'block';

    if (!dayOpen && !monthOpen) {
      var overlay = document.getElementById('modalOverlay');
      if (overlay) overlay.style.display = 'none';
    }
  }

  async function deleteAppointmentAjax(apptId) {
    var token = getAntiForgeryToken();

    var body = new URLSearchParams();
    body.append('id', apptId);
    body.append('__RequestVerificationToken', token);

    var res = await fetch('/Appointment/DeleteAjax', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
      body: body.toString()
    });

    if (!res.ok) throw new Error('HTTP ' + res.status);

    var json = await res.json();
    if (!json || json.ok !== true) {
      throw new Error((json && json.message) ? json.message : 'Delete failed');
    }
    return json;
  }

  function removeAppointmentFromUI(apptId) {
    allAppointments = (allAppointments || []).filter(function (a) {
      return String(a.ApptId) !== String(apptId);
    });

    document.querySelectorAll('.appt-card.modal-card[data-appt-id="' + cssEscape(apptId) + '"]').forEach(function (n) {
      n.remove();
    });

    document.querySelectorAll('.appt-card.in-cell[data-appt-id="' + cssEscape(apptId) + '"]').forEach(function (n) {
      n.remove();
    });

    var dayList = document.getElementById('day-appointments-list');
    if (dayList && dayList.children.length === 0) dayList.innerHTML = '<div class="appt-empty">No appointments.</div>';

    var monthList = document.getElementById('month-appointments-list');
    if (monthList && monthList.children.length === 0) monthList.innerHTML = '<div class="appt-empty">No appointments.</div>';
  }

  function wireDeleteConfirm(containerEl) {
    if (!containerEl) return;

    containerEl.querySelectorAll('a.appt-delete').forEach(function (a) {
      a.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        var apptId = a.getAttribute('data-appt-id');
        openConfirmDeleteModal(apptId);
      });
    });
  }

  // ====== STATUS UPDATE AJAX ======
  async function setAppointmentStatus(apptId, newStatus) {
    var token = getAntiForgeryToken();

    var body = new URLSearchParams();
    body.append('id', apptId);
    body.append('status', newStatus);
    body.append('__RequestVerificationToken', token);

    var res = await fetch('/Appointment/SetStatus', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
      body: body.toString()
    });

    if (!res.ok) throw new Error('HTTP ' + res.status);

    var json = await res.json();
    if (!json || json.ok !== true) throw new Error((json && json.message) ? json.message : 'Update failed');

    return json;
  }

  function wireTodoCheckboxes(containerEl) {
    if (!containerEl) return;

    containerEl.querySelectorAll('.appt-done-cb').forEach(function (cb) {
      cb.addEventListener('click', function (e) { e.stopPropagation(); });

      cb.addEventListener('change', async function (e) {
        e.stopPropagation();

        var card = cb.closest('.appt-card');
        if (!card) return;

        var apptId = cb.getAttribute('data-appt-id') || card.getAttribute('data-appt-id');
        var wantDone = cb.checked;
        var newStatus = wantDone ? 'FULFILLED' : 'BOOKED';

        card.classList.toggle('is-fulfilled', wantDone);
        card.classList.add('appt-saving');

        try {
          await setAppointmentStatus(apptId, newStatus);

          var found = (allAppointments || []).find(function (a) { return String(a.ApptId) === String(apptId); });
          if (found) found.Status = newStatus;

        } catch (err) {
          cb.checked = !wantDone;
          card.classList.toggle('is-fulfilled', !wantDone);
          alert('Failed to update status: ' + (err && err.message ? err.message : err));
        } finally {
          card.classList.remove('appt-saving');
        }
      });
    });
  }

  // =========================
  // ✅ Title click dropdown (services list)
  // =========================
  function getServiceLinesHtml(apptId) {
    var list = (window.apptServices && window.apptServices[apptId]) ? window.apptServices[apptId] : null;
    if (!list || !Array.isArray(list) || list.length <= 1) return '';

    var html = '<div class="appt-services" style="display:none; margin-top:6px; padding-top:6px; border-top:1px dashed rgba(0,0,0,0.15);">';
    html += '<div style="font-size:12px; font-weight:700; margin-bottom:4px;">Services</div>';

    list.forEach(function (code) {
      var name = (window.serviceNames && window.serviceNames[code]) ? window.serviceNames[code] : code;
      html += '<div class="appt-service-line" style="font-size:12px; line-height:1.35;">- ' + escHtml(name) + '</div>';
    });

    html += '</div>';
    return html;
  }

  function wireTitleDropdown(containerEl) {
    if (!containerEl) return;

    containerEl.querySelectorAll('.appt-title-toggle').forEach(function (t) {
      t.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();

        var card = t.closest('.appt-card');
        if (!card) return;

        var panel = card.querySelector('.appt-services');
        if (!panel) return;

        var isOpen = panel.style.display === 'block';
        panel.style.display = isOpen ? 'none' : 'block';

        var more = t.querySelector('.appt-more');
        if (more) more.textContent = isOpen ? '(more)' : '(less)';
      });
    });
  }

  // ====== Build appointment card for modal ======
  function buildApptCard(appt) {
    var when = '';
    var timeOnly = '';
    if (appt.ApptStart) {
      when = appt.ApptStart.replace('T', ' ').substring(0, 16);
      timeOnly = appt.ApptStart.replace('T', ' ').substring(11, 16);
    }

    var cust = (window.customerNames && window.customerNames[appt.CustomerCode])
      ? window.customerNames[appt.CustomerCode]
      : (appt.CustomerCode || '');

    var agent = (window.agentNames && window.agentNames[appt.AgentCode])
      ? window.agentNames[appt.AgentCode]
      : (appt.AgentCode || '');

    var cardColor = (window.agentColors && window.agentColors[appt.AgentCode])
      ? window.agentColors[appt.AgentCode]
      : null;

    var style = cardColor ? ' style="background-color:' + escHtml(cardColor) + ' !important;"' : '';
    var done = isFulfilled(appt);
    var doneClass = done ? ' is-fulfilled' : '';

    // ✅ services dropdown only if >1 service
    var servicesHtml = getServiceLinesHtml(appt.ApptId);
    var hasMultiServices = servicesHtml && servicesHtml.length > 0;

    var titleHtml =
      '<div class="appt-title appt-title-toggle" style="cursor:' + (hasMultiServices ? 'pointer' : 'default') + '; display:flex; align-items:center; gap:8px;">' +
        '<span>' + escHtml(toTitleCase(appt.Title || '')) + '</span>' +
        (hasMultiServices
          ? '<span class="appt-more" style="font-size:12px; font-weight:700; opacity:0.85;">(more)</span>'
          : ''
        ) +
      '</div>';

    // ✅ IMPORTANT: hide Edit / Submit E-Sign / Delete when fulfilled
    var actionsHtml = '';
    if (!done) {
      actionsHtml =
        '<div class="appt-actions" style="margin-top:6px; display:flex; gap:6px; align-items:center; flex-wrap:wrap;">' +
          '<a href="/Appointment/Edit/' + appt.ApptId + '" class="btn btn-sm btn-primary">Edit</a>' +
          '<a href="/Appointment/Sign/' + appt.ApptId + '" class="btn btn-sm btn-secondary">Submit E-Sign</a>' +
          '<a href="#" class="btn btn-sm btn-danger appt-delete" data-appt-id="' + appt.ApptId + '">Delete</a>' +
        '</div>';
    }

    return (
      '<div class="appt-card modal-card' + doneClass + '" data-appt-id="' + appt.ApptId + '"' + style + '>' +
        '<div class="appt-top">' +
          '<div>' + titleHtml + '</div>' +
          '<div class="appt-top-right">' +
            '<div class="appt-time">' + escHtml(timeOnly || '') + '</div>' +
          '</div>' +
        '</div>' +

        // ✅ services panel
        servicesHtml +

        '<div class="appt-meta" style="margin-top:6px;">' +
          '<div class="appt-meta-line"><span class="appt-meta-label">When:</span> <span class="appt-meta-value">' + escHtml(when) + '</span></div>' +
          '<div class="appt-meta-line"><span class="appt-meta-label">Cust:</span> <span class="appt-meta-value">' + escHtml(cust) + '</span></div>' +
          '<div class="appt-meta-line"><span class="appt-meta-label">Agent:</span> <span class="appt-meta-value">' + escHtml(agent) + '</span></div>' +

          // ✅ buttons only when NOT fulfilled
          actionsHtml +

        '</div>' +
      '</div>'
    );
  }

  // ====== show modals ======
  function showMonthModal(year, month) {
    var modalEl = document.getElementById('monthAppointmentsModal');
    var label = document.getElementById('modalMonthLabel');
    var list = document.getElementById('month-appointments-list');
    var overlay = document.getElementById('modalOverlay');

    var monthStr = year + '-' + (month.toString().length === 1 ? '0' + month : month);
    label.textContent = monthStr;
    list.innerHTML = '';

    var appts = (allAppointments || []).filter(function (a) {
      return a.ApptStart && a.ApptStart.startsWith(monthStr);
    });

    if (appts.length === 0) {
      list.innerHTML = '<div class="appt-empty">No appointments.</div>';
    } else {
      appts.sort(function (a, b) { return (a.ApptStart || '').localeCompare(b.ApptStart || ''); });

      var html = '';
      appts.forEach(function (appt) { html += buildApptCard(appt); });
      list.innerHTML = html;

      wireTodoCheckboxes(list);
      wireDeleteConfirm(list);
      wireTitleDropdown(list);
    }

    overlay.style.display = 'block';
    modalEl.style.display = 'block';
  }

  function showDayModal(date) {
    var modalEl = document.getElementById('dayAppointmentsModal');
    var label = document.getElementById('modalDayLabel');
    var list = document.getElementById('day-appointments-list');
    var addBtn = document.getElementById('add-appointment-btn');
    var overlay = document.getElementById('modalOverlay');

    try {
      var d = new Date(date);
      if (!isNaN(d.getTime())) {
        label.textContent = d.getDate() + ' ' + d.toLocaleString('default', { month: 'long' }) + ' ' + d.getFullYear();
      } else {
        label.textContent = date;
      }
    } catch (e) {
      label.textContent = date;
    }

    addBtn.href = '/Appointment/Create?apptStart=' + date + 'T09:00';
    list.innerHTML = '';

    var appts = (allAppointments || []).filter(function (a) {
      return a.ApptStart && a.ApptStart.startsWith(date);
    });

    if (appts.length === 0) {
      list.innerHTML = '<div class="appt-empty">No appointments.</div>';
    } else {
      appts.sort(function (a, b) { return (a.ApptStart || '').localeCompare(b.ApptStart || ''); });

      var html = '';
      appts.forEach(function (appt) { html += buildApptCard(appt); });
      list.innerHTML = html;

      wireTodoCheckboxes(list);
      wireDeleteConfirm(list);
      wireTitleDropdown(list);
    }

    overlay.style.display = 'block';
    modalEl.style.display = 'block';
  }

  // ====== init ======
  document.addEventListener('DOMContentLoaded', function () {

    document.querySelectorAll('.calendar-cell-day').forEach(function (cell) {
      cell.addEventListener('click', function (e) {
        e.stopPropagation();
        showDayModal(cell.getAttribute('data-date'));
      });

      cell.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          showDayModal(cell.getAttribute('data-date'));
        }
      });
    });

    function closeMainModals() {
      document.getElementById('dayAppointmentsModal').style.display = 'none';
      document.getElementById('monthAppointmentsModal').style.display = 'none';
      document.getElementById('modalOverlay').style.display = 'none';
    }

    document.getElementById('closeDayModal').addEventListener('click', closeMainModals);
    document.getElementById('closeMonthModal').addEventListener('click', closeMainModals);
    document.getElementById('modalOverlay').addEventListener('click', closeMainModals);
    document.getElementById('modalOverlay').addEventListener('touchstart', closeMainModals);

    document.querySelectorAll('.custom-modal-content').forEach(function (modalContent) {
      modalContent.addEventListener('mousedown', function (e) { e.stopPropagation(); });
      modalContent.addEventListener('touchstart', function (e) { e.stopPropagation(); });
    });

    // confirm delete modal buttons
    var btnCancel = document.getElementById('btnDeleteCancel');
    var btnYes = document.getElementById('btnDeleteYes');
    var btnCloseX = document.getElementById('closeConfirmDeleteModal');

    if (btnCancel) btnCancel.addEventListener('click', function (e) {
      e.preventDefault();
      closeConfirmDeleteModal();
    });

    if (btnCloseX) btnCloseX.addEventListener('click', function (e) {
      e.preventDefault();
      closeConfirmDeleteModal();
    });

    if (btnYes) btnYes.addEventListener('click', async function (e) {
      e.preventDefault();

      if (!pendingDeleteId) {
        closeConfirmDeleteModal();
        return;
      }

      btnYes.disabled = true;

      try {
        await deleteAppointmentAjax(pendingDeleteId);
        removeAppointmentFromUI(pendingDeleteId);
        closeConfirmDeleteModal();
      } catch (err) {
        alert('Failed to delete appointment: ' + (err && err.message ? err.message : err));
      } finally {
        btnYes.disabled = false;
      }
    });
  });
</script>

}
