@model YourApp.Models.TenantBrandingVm
@{
    var m = Model ?? new YourApp.Models.TenantBrandingVm();
}

<header class="custom-header bg-light border-bottom mb-3">
    <div class="container py-3">
        <div class="d-flex flex-column align-items-center text-center gap-2">

            @if (!string.IsNullOrWhiteSpace(m.HeaderLogoUrl))
            {
                <img src="@m.HeaderLogoUrl"
                     alt="@m.TenantName"
                     style="max-height:48px; max-width:160px; object-fit:contain;" />
            }

            <div class="d-flex flex-column align-items-center">
                <span class="h5 fw-bold text-primary mb-0">
                    @(string.IsNullOrWhiteSpace(m.TenantName) ? "My Company" : m.TenantName)
                </span>

                @if (!string.IsNullOrWhiteSpace(m.HeaderText1) || !string.IsNullOrWhiteSpace(m.HeaderText2))
                {
                    <small class="text-muted">
                        @m.HeaderText1
                        @if (!string.IsNullOrWhiteSpace(m.HeaderText2))
                        {
                            <span> · @m.HeaderText2</span>
                        }
                    </small>
                }
            </div>

        </div>
    </div>
</header>
