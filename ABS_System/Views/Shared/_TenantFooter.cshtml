@model YourApp.Models.TenantBrandingVm

<footer class="custom-footer bg-light border-top text-muted mt-4 py-3">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
        <div class="d-flex flex-column">
            <span>
                &copy; @DateTime.Now.Year -
                @(string.IsNullOrWhiteSpace(Model.TenantName) ? "My Company" : Model.TenantName)
            </span>
            @if (!string.IsNullOrWhiteSpace(Model.FooterText1)
               || !string.IsNullOrWhiteSpace(Model.FooterText2)
               || !string.IsNullOrWhiteSpace(Model.FooterText3))
            {
                <small class="text-muted">
                    @Model.FooterText1
                    @if (!string.IsNullOrWhiteSpace(Model.FooterText2))
                    {
                        <span> · @Model.FooterText2</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.FooterText3))
                    {
                        <span> · @Model.FooterText3</span>
                    }
                </small>
            }
        </div>

        <div class="d-flex align-items-center gap-3 mt-2 mt-md-0">
            @if (!string.IsNullOrWhiteSpace(Model.FooterImageUrl))
            {
                <img src="@Model.FooterImageUrl"
                     alt="Footer image"
                     style="max-height:32px; max-width:120px; object-fit:contain;" />
            }
            <nav>
                <a class="text-muted me-3" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <a class="text-muted me-3" asp-area="" asp-controller="Calendar" asp-action="Index">Calendar</a>
                <a class="text-muted me-3" asp-area="" asp-controller="Appointment" asp-action="Index">Appointments</a>
                <a class="text-muted" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </nav>
        </div>
    </div>
</footer>

