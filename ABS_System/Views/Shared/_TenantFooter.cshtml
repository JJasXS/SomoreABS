@model YourApp.Models.TenantBrandingVm
@{
    var m = Model ?? new YourApp.Models.TenantBrandingVm();
}

<footer class="custom-footer bg-light border-top text-muted mt-4 py-3">
    <div class="container">
        <div class="d-flex flex-column align-items-center text-center">

           
            @if (!string.IsNullOrWhiteSpace(m.FooterText1)
               || !string.IsNullOrWhiteSpace(m.FooterText2)
               || !string.IsNullOrWhiteSpace(m.FooterText3))
            {
                <small class="text-muted">
                    @m.FooterText1
                    @if (!string.IsNullOrWhiteSpace(m.FooterText2))
                    {
                        <span> · @m.FooterText2</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(m.FooterText3))
                    {
                        <br />@m.FooterText3
                    }
                </small>
            }

        </div>
    </div>
</footer>
