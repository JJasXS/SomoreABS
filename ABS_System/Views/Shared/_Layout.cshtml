@using YourApp.Models
@{
    var tenant = ViewBag.TenantBranding as TenantBrandingVm;
    var pageTitle = ViewData["Title"] as string ?? "YourApp";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>

    <!-- ✅ Bootstrap (required for btn, container, card, etc.) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- ✅ Your custom layout CSS -->
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />

    <!-- Optional site css if you have it -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">

    @await Html.PartialAsync("~/Views/Shared/_TenantHeader.cshtml", tenant)

    <main class="flex-fill">
        @RenderBody()
    </main>

    @await Html.PartialAsync("~/Views/Shared/_TenantFooter.cshtml", tenant)

    <!-- ✅ Bootstrap JS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
