@using YourApp.Models
@{
    var tenant = ViewBag.TenantBranding as TenantBrandingVm;
    var pageTitle = ViewData["Title"] as string ?? "YourApp";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>

    <!-- ✅ Bootstrap (required for btn, container, card, etc.) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- ✅ Your custom layout CSS -->
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />

    <!-- Optional site css if you have it -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
      /* Theme variables */
      :root{
        --app-bg: #ffffff;
        --app-fg: #111111;
        --card-bg: #ffffff;
        --card-border: rgba(0,0,0,0.12);
        --muted: rgba(0,0,0,0.65);
      }

      html.theme-dark{
        color-scheme: dark;
        --app-bg: #0f1115;
        --app-fg: #e9eef5;
        --card-bg: #151923;
        --card-border: rgba(255,255,255,0.14);
        --muted: rgba(233,238,245,0.72);
      }

      body{
        background: var(--app-bg);
        color: var(--app-fg);
      }

      /* Generic surfaces */
      .card, .custom-modal-content, .booking-form, .side-menu{
        background: var(--card-bg) !important;
        color: var(--app-fg) !important;
        border-color: var(--card-border) !important;
      }

      .modal-overlay, .side-menu-overlay{
        background: rgba(0,0,0,0.45) !important;
      }

      /* Inputs */
      input, select, textarea{
        background: var(--card-bg);
        color: var(--app-fg);
        border-color: var(--card-border);
      }

      /* Text helpers */
      .text-muted, .muted, small, .form-text{
        color: var(--muted) !important;
      }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    @await Html.PartialAsync("~/Views/Shared/_TenantHeader.cshtml", tenant)

    <main class="flex-fill d-flex flex-column">
        @RenderBody()
    </main>

    @await Html.PartialAsync("~/Views/Shared/_TenantFooter.cshtml", tenant)

    <!-- ✅ Bootstrap JS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
      (function(){
        const KEY = 'abs.theme';

        function apply(theme){
          const t = (theme === 'dark') ? 'dark' : 'light';
          document.documentElement.classList.toggle('theme-dark', t === 'dark');
          try { localStorage.setItem(KEY, t); } catch(e) {}
          window.dispatchEvent(new CustomEvent('themechanged', { detail: { theme: t } }));
        }

        function get(){
          try {
            const v = localStorage.getItem(KEY);
            if (v === 'dark' || v === 'light') return v;
          } catch(e) {}
          return 'light';
        }

        window.setAppTheme = apply;
        window.getAppTheme = get;
        apply(get());
      })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
