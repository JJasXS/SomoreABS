@model YourApp.Models.Appointment
@using System.Collections.Generic
@using System.Linq

@{
    var serviceItemsList = ViewBag.ServiceItems as List<YourApp.Models.ST_ITEM>
                           ?? new List<YourApp.Models.ST_ITEM>();

    var selectedCodes = ViewBag.SelectedServiceCodes as List<string> ?? new List<string>();
}

<h2>Edit Appointment</h2>

<style>
  /* ===============================
     Edit Appointment - Full Styles
     Copy paste replace your <style>
     =============================== */

  .booking-form {
    max-width: 460px;
    margin: 0 auto;
    background: #f8f9fa;
    border-radius: 12px;
    padding: 28px 26px 22px 26px;
    box-shadow: 0 2px 14px rgba(0,0,0,0.08);
  }

  h2 {
    text-align: center;
    margin: 18px 0 14px 0;
  }

  /* labels */
  .booking-form label {
    font-weight: 700;
    margin-bottom: 6px;
    display: block;
    color: #222;
  }

  /* inputs + selects */
  .booking-form input,
  .booking-form select {
    width: 100%;
    padding: 9px 10px;
    margin-bottom: 16px;         /* ✅ general spacing */
    border: 1px solid #cfcfcf;
    border-radius: 8px;
    font-size: 1em;
    background: #fff;
    height: 42px;                /* ✅ consistent control height */
    box-sizing: border-box;
  }

  .booking-form input[type="datetime-local"] {
    height: 42px;
  }

  /* validation summary */
  .validation-summary {
    background: #fff3f3;
    border: 1px solid #f5c2c7;
    color: #842029;
    border-radius: 10px;
    padding: 10px 12px;
    margin-bottom: 14px;
    font-size: .95em;
  }
  .validation-summary ul { margin: 0; padding-left: 18px; }

  /* =========================
     Services section
     ========================= */

  /* extra spacing after Appointment Time section */
  .booking-form > div:nth-of-type(3) {
    margin-bottom: 6px;
  }

  .svc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 10px;            /* ✅ spacing before services section */
    margin-bottom: 10px;         /* ✅ spacing between header and first row */
  }

  .svc-add-btn {
    padding: 8px 12px;
    border-radius: 10px;
    border: none;
    background: #198754;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
    height: 38px;
    line-height: 1;
  }
  .svc-add-btn:hover { filter: brightness(0.95); }

  /* container spacing above rows */
  #serviceRows {
    margin-top: 6px;             /* ✅ gap between header and dropdown rows */
  }

  .svc-row {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 14px;         /* ✅ spacing between rows */
  }

  .svc-row select {
    margin-bottom: 0;            /* ✅ prevent double gaps */
    height: 42px;
  }

  .svc-remove-btn {
    padding: 0 12px;
    border-radius: 10px;
    border: none;
    background: #dc3545;
    color: #fff;
    font-weight: 900;
    cursor: pointer;
    height: 42px;                /* ✅ match select height */
    min-width: 44px;
    line-height: 42px;
  }
  .svc-remove-btn:hover { filter: brightness(0.95); }

  .svc-hint {
    display: block;
    margin-top: 6px;
    font-size: .92em;
    color: #6c757d;
  }

  /* optional message box (if you use it later) */
  .svc-msg {
    display: none;
    margin-top: 10px;
    font-size: .92em;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid rgba(0,0,0,0.10);
    background: rgba(255,255,255,0.75);
    color: #333;
  }
  .svc-msg.is-err {
    display: block;
    border-color: #f5c2c7;
    background: #fff3f3;
    color: #842029;
  }

  /* =========================
     Form actions buttons
     ========================= */
  .booking-form .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 14px;
  }

  .booking-form button[type="submit"],
  .booking-form a {
    padding: 10px 18px;
    border-radius: 10px;
    border: none;
    font-size: 1em;
    font-weight: 700;
    text-decoration: none;
    color: #fff;
    background: #007bff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    flex: 1;                     /* ✅ equal width buttons */
  }

  .booking-form a {
    background: #6c757d;
  }

  .booking-form button[type="submit"]:hover,
  .booking-form a:hover {
    filter: brightness(0.95);
  }
</style>


<form asp-action="Edit" method="post" class="booking-form" id="apptForm">
  @Html.AntiForgeryToken()
  <div asp-validation-summary="All" class="validation-summary"></div>

  <input type="hidden" asp-for="ApptId" />
  <input type="hidden" asp-for="Title" id="TitleHidden" />

  <div>
    <label>Customer</label>
    <select asp-for="CustomerCode">
      <option value="">-- Select Customer --</option>
      @if (ViewBag.Customers != null)
      {
        foreach (var cust in (List<dynamic>)ViewBag.Customers)
        {
          var selected = Model.CustomerCode == cust.Code ? "selected" : null;
          <option value="@cust.Code" selected="@selected">@cust.Name</option>
        }
      }
    </select>
  </div>

  <div>
    <label>Agent</label>
    <select asp-for="AgentCode">
      <option value="">-- Select Agent --</option>
      @if (ViewBag.Agents != null)
      {
        foreach (var agent in (List<dynamic>)ViewBag.Agents)
        {
          var selected = Model.AgentCode == agent.Code ? "selected" : null;
          <option value="@agent.Code" selected="@selected">@agent.Description</option>
        }
      }
    </select>
  </div>

  <div>
    <label>Appointment Time</label>
    <input asp-for="ApptStart" type="datetime-local"
           value="@Model.ApptStart.ToString("yyyy-MM-ddTHH:mm")" />
  </div>

  <div>
    <div class="svc-header">
      <label style="margin:0;">Services</label>
      <button type="button" id="btnAddService" class="svc-add-btn">+ Add</button>
    </div>

    <input type="hidden" name="ServiceCodes" id="ServiceCodesHidden" value="" />
    <div id="serviceRows"></div>

    <div id="svcMsg" class="svc-msg"></div>

    <small class="svc-hint">Tip: Pick 1 or more services. Title will auto-fill from first service.</small>
  </div>

  <div class="form-actions">
    <button type="submit">Save</button>
    <a asp-controller="Calendar" asp-action="Index">Cancel</a>
  </div>
</form>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />

  <script>
    // ---------------------------
    // Data from server
    // ---------------------------
    const serviceItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
      serviceItemsList.Select(x => new { code = x.CODE, desc = x.DESCRIPTION }).ToList()
    ));

    const preselected = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(selectedCodes));

    // ---------------------------
    // Utils
    // ---------------------------
    function escHtml(s) {
      return (s || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function setSvcMessage(msg, isErr) {
      const el = document.getElementById('svcMsg');
      if (!el) return;

      if (!msg) {
        el.classList.remove('is-err');
        el.style.display = 'none';
        el.innerHTML = '';
        return;
      }

      el.innerHTML = escHtml(msg);
      el.classList.toggle('is-err', !!isErr);
      el.style.display = 'block';
    }

    function buildSelectHtml(selectedValue) {
      let html = `<select class="svc-dd">`;
      html += `<option value="">-- Select Service --</option>`;
      for (const it of serviceItems) {
        const code = (it.code || '').trim();
        const text = `${code} - ${(it.desc || '').trim()}`;
        const sel = (selectedValue && selectedValue === code) ? 'selected' : '';
        html += `<option value="${escHtml(code)}" ${sel}>${escHtml(text)}</option>`;
      }
      html += `</select>`;
      return html;
    }

    function computeTitleFromCodes(codes) {
      if (!codes || codes.length === 0) return '';
      const first = codes[0];
      return (codes.length > 1) ? (first + '...') : first;
    }

    function getSelectedCodesRaw() {
      return Array.from(document.querySelectorAll('.svc-dd'))
        .map(x => (x.value || '').trim())
        .filter(x => x.length > 0);
    }

    function getSelectedCodesUniquePreserveOrder(codes) {
      const uniq = [];
      const seen = {};
      for (const c of codes) {
        const k = c.toLowerCase();
        if (!seen[k]) {
          uniq.push(c);
          seen[k] = true;
        }
      }
      return uniq;
    }

    // ---------------------------
    // Sync hidden fields
    // ---------------------------
    function syncHidden() {
      const raw = getSelectedCodesRaw();
      const uniq = getSelectedCodesUniquePreserveOrder(raw);

      document.getElementById('ServiceCodesHidden').value = uniq.join(',');
      document.getElementById('TitleHidden').value = computeTitleFromCodes(uniq);
    }

    // ---------------------------
    // Duplicate prevention on change:
    // if user selects service already used in another row, revert to blank
    // ---------------------------
    function preventDuplicate(selectEl) {
      if (!selectEl) return;

      const val = (selectEl.value || '').trim();
      if (!val) { setSvcMessage('', false); return; }

      const all = Array.from(document.querySelectorAll('.svc-dd'));
      const dupCount = all.filter(x => (x.value || '').trim().toLowerCase() === val.toLowerCase()).length;

      if (dupCount > 1) {
        selectEl.value = '';
        setSvcMessage('This service is already selected. Please choose a different service.', true);
      } else {
        setSvcMessage('', false);
      }
    }

    // ---------------------------
    // UI row add/remove
    // ---------------------------
    function addRow(selectedValue) {
      const row = document.createElement('div');
      row.className = 'svc-row';

      row.innerHTML =
        `<div style="flex:1;">${buildSelectHtml(selectedValue)}</div>` +
        `<button type="button" class="svc-remove-btn" title="Remove">×</button>`;

      document.getElementById('serviceRows').appendChild(row);

      const btnRemove = row.querySelector('.svc-remove-btn');
      const dd = row.querySelector('.svc-dd');

      btnRemove.addEventListener('click', function () {
        row.remove();
        setSvcMessage('', false);
        syncHidden();
      });

      dd.addEventListener('change', function () {
        preventDuplicate(dd);
        syncHidden();
      });

      // initial sync
      syncHidden();
    }

    // ---------------------------
    // Submit validation
    // ---------------------------
    function validateBeforeSubmit() {
      // must have at least 1 service selected
      const uniq = getSelectedCodesUniquePreserveOrder(getSelectedCodesRaw());
      if (!uniq || uniq.length === 0) {
        setSvcMessage('Please select at least one service before saving.', true);
        return false;
      }
      setSvcMessage('', false);
      return true;
    }

    // ---------------------------
    // Init
    // ---------------------------
    document.addEventListener('DOMContentLoaded', function () {

      // Preload existing selections (Edit)
      if (Array.isArray(preselected) && preselected.length > 0) {
        for (const c of preselected) addRow((c || '').trim());
      } else {
        addRow('');
      }

      document.getElementById('btnAddService').addEventListener('click', function () {
        addRow('');
      });

      const form = document.getElementById('apptForm');
      if (form) {
        form.addEventListener('submit', function (e) {
          syncHidden();

          if (!validateBeforeSubmit()) {
            e.preventDefault();
            e.stopPropagation();
            return false;
          }
        });
      }
    });
  </script>
}
