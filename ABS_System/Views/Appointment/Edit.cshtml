@model YourApp.Models.Appointment
@using System.Collections.Generic
@using System.Linq

@{
    var selectedCodes = ViewBag.SelectedServiceCodes as List<string> ?? new List<string>();
}

<h2>Edit Appointment</h2>

<style>
  /* =========================
   Two columns (Customer + Agent)
   ========================= */
  .two-col{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  @@media (max-width: 520px){
    .two-col{ grid-template-columns: 1fr; }
  }

  /* =========================
   Date + Time side-by-side row
   ========================= */
  .dt-row{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .dt-col label{
    margin-top: 0;
  }

  /* Mobile: stack */
  @@media (max-width: 520px){
    .dt-row{ grid-template-columns: 1fr; }
  }

  /* ===============================
     Edit Appointment - Full Styles
     =============================== */
  .booking-form {
    max-width: 460px;
    margin: 0 auto;
    background: #f8f9fa;
    border-radius: 12px;
    padding: 28px 26px 22px 26px;
    box-shadow: 0 2px 14px rgba(0,0,0,0.08);
  }

  h2 {
    text-align: center;
    margin: 18px 0 14px 0;
  }

  .booking-form label {
    font-weight: 700;
    margin-bottom: 6px;
    display: block;
    color: #222;
  }

  .booking-form input,
  .booking-form select {
    width: 100%;
    padding: 9px 10px;
    margin-bottom: 16px;
    border: 1px solid #cfcfcf;
    border-radius: 8px;
    font-size: 1em;
    background: #fff;
    height: 42px;
    box-sizing: border-box;
  }

  .booking-form input[type="datetime-local"] {
    height: 42px;
  }

  .validation-summary {
    background: #fff3f3;
    border: 1px solid #f5c2c7;
    color: #842029;
    border-radius: 10px;
    padding: 10px 12px;
    margin-bottom: 14px;
    font-size: .95em;
  }
  .validation-summary ul { margin: 0; padding-left: 18px; }

  /* =========================
     Services section
     ========================= */
  .svc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 10px;
    margin-bottom: 10px;
  }

  .svc-add-btn {
    padding: 8px 12px;
    border-radius: 10px;
    border: none;
    background: #198754;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
    height: 38px;
    line-height: 1;
  }
  .svc-add-btn:hover { filter: brightness(0.95); }

  #serviceRows { margin-top: 6px; }

  .svc-row {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-bottom: 14px;
  }

  .svc-row select {
    margin-bottom: 0;
    height: 42px;
  }

  .svc-remove-btn {
    padding: 0 12px;
    border-radius: 10px;
    border: none;
    background: #dc3545;
    color: #fff;
    font-weight: 900;
    cursor: pointer;
    height: 42px;
    min-width: 44px;
    line-height: 42px;
  }
  .svc-remove-btn:hover { filter: brightness(0.95); }

  .svc-hint {
    display: block;
    margin-top: 6px;
    font-size: .92em;
    color: #6c757d;
  }

  .svc-msg {
    display: none;
    margin-top: 10px;
    font-size: .92em;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid rgba(0,0,0,0.10);
    background: rgba(255,255,255,0.75);
    color: #333;
  }
  .svc-msg.is-err {
    display: block;
    border-color: #f5c2c7;
    background: #fff3f3;
    color: #842029;
  }

  /* ✅ tiny helper text for loading */
  .svc-loading{
    font-size: 0.92em;
    color: #0d6efd;
    margin: 6px 0 0;
    display: none;
  }

  /* =========================
     Form actions buttons
     ========================= */
  .booking-form .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 14px;
  }

  .booking-form button[type="submit"],
  .booking-form a {
    padding: 10px 18px;
    border-radius: 10px;
    border: none;
    font-size: 1em;
    font-weight: 700;
    text-decoration: none;
    color: #fff;
    background: #007bff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    flex: 1;
  }

  .booking-form a {
    background: #6c757d;
  }

  .booking-form button[type="submit"]:hover,
  .booking-form a:hover {
    filter: brightness(0.95);
  }
</style>

<form asp-action="Edit" method="post" class="booking-form" id="apptForm">
  @Html.AntiForgeryToken()
  <div asp-validation-summary="All" class="validation-summary"></div>

  <input type="hidden" asp-for="ApptId" />
  <input type="hidden" asp-for="Title" id="TitleHidden" />

  <div class="two-col">
    <div>
      <label>Customer</label>
      <!-- ✅ IMPORTANT: id="CustomerCode" so JS can reload services -->
      <select asp-for="CustomerCode" id="CustomerCode">
        <option value="">-- Select Customer --</option>
        @if (ViewBag.Customers != null)
        {
          foreach (var cust in (List<dynamic>)ViewBag.Customers)
          {
            var selected = Model.CustomerCode == cust.Code ? "selected" : null;
            <option value="@cust.Code" selected="@selected">@cust.Name</option>
          }
        }
      </select>
    </div>

    <div>
      <label>Agent</label>
      <select asp-for="AgentCode" id="AgentCode">
        <option value="">-- Select Agent --</option>
        @if (ViewBag.Agents != null)
        {
          foreach (var agent in (List<dynamic>)ViewBag.Agents)
          {
            var selected = Model.AgentCode == agent.Code ? "selected" : null;
            <option value="@agent.Code" selected="@selected">@agent.Description</option>
          }
        }
      </select>
    </div>
  </div>

  <!-- ✅ Split Date + Time (still submit ApptStart) -->
  <div>
    <div class="dt-row">
      <div class="dt-col">
        <label>Appointment Date</label>
        <input type="date" id="ApptDate" value="@Model.ApptStart.ToString("yyyy-MM-dd")" />
      </div>

      <div class="dt-col">
        <label>Appointment Time</label>
        <input type="time" id="ApptTime" value="@Model.ApptStart.ToString("HH:mm")" />
      </div>
    </div>

    <!-- ✅ Hidden real field that is submitted to controller -->
    <input asp-for="ApptStart" type="datetime-local" id="ApptStartHidden" style="display:none;"
           value="@Model.ApptStart.ToString("yyyy-MM-ddTHH:mm")" />
  </div>

  <div>
    <div class="svc-header">
      <label style="margin:0;">Services</label>
      <button type="button" id="btnAddService" class="svc-add-btn">+ Add</button>
    </div>

    <div class="svc-loading" id="svcLoading">Loading services for customer...</div>

    <input type="hidden" name="ServiceCodes" id="ServiceCodesHidden" value="" />
    <div id="serviceRows"></div>

    <div id="svcMsg" class="svc-msg"></div>

    <small class="svc-hint">Tip: Select services purchased by this customer.</small>
  </div>

  <div class="form-actions">
    <button type="submit">Save</button>
    <a asp-controller="Calendar" asp-action="Index">Cancel</a>
  </div>
</form>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />

  <script>
    // ✅ AJAX-loaded services for selected customer
    let serviceItems = [];

    // ✅ preselected from APPT_DTL
    const preselected = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(selectedCodes));

    // ✅ Date+Time => hidden ApptStart
    function syncApptStartHidden() {
      const d = (document.getElementById('ApptDate')?.value || '').trim();
      const t = (document.getElementById('ApptTime')?.value || '').trim();
      const hidden = document.getElementById('ApptStartHidden');
      if (!hidden) return;

      if (!d || !t) { hidden.value = ''; return; }
      hidden.value = `${d}T${t}`;
    }

    function escHtml(s) {
      return (s || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function setSvcMessage(msg, isErr) {
      const el = document.getElementById('svcMsg');
      if (!el) return;

      if (!msg) {
        el.classList.remove('is-err');
        el.style.display = 'none';
        el.innerHTML = '';
        return;
      }

      el.innerHTML = escHtml(msg);
      el.classList.toggle('is-err', !!isErr);
      el.style.display = 'block';
    }

    function buildSelectHtml(selectedValue) {
      let html = `<select class="svc-dd">`;
      html += `<option value="">-- Select Service --</option>`;

      for (const it of serviceItems) {
        const code = (it.code || '').trim();
        let desc = (it.desc || '').trim();
        const balance = typeof it.balance === 'number' ? it.balance : null;
        let balanceHtml = '';
        if (balance !== null) {
          const color = balance > 0 ? 'green' : 'red';
          balanceHtml = `<span style='color:${color};font-weight:bold;'> (Balance: ${balance})</span>`;
        }
        let text = `${code} - ${escHtml(desc)}${balanceHtml}`;
        const sel = (selectedValue && selectedValue === code) ? 'selected' : '';
        if (desc.includes('(Last one!)')) {
          text = `${code} - <span style='color:red;font-weight:bold;'>${escHtml(desc)}</span>${balanceHtml}`;
        }
        html += `<option value="${escHtml(code)}" ${sel}>${text}</option>`;
      }

      html += `</select>`;
      return html;
    }

    function computeTitleFromCodes(codes) {
      if (!codes || codes.length === 0) return '';
      const first = codes[0];
      return (codes.length > 1) ? (first + '...') : first;
    }

    function getSelectedCodesRaw() {
      return Array.from(document.querySelectorAll('.svc-dd'))
        .map(x => (x.value || '').trim())
        .filter(x => x.length > 0);
    }

    function getSelectedCodesUniquePreserveOrder(codes) {
      const uniq = [];
      const seen = {};
      for (const c of codes) {
        const k = c.toLowerCase();
        if (!seen[k]) { uniq.push(c); seen[k] = true; }
      }
      return uniq;
    }

    function syncHidden() {
      const raw = getSelectedCodesRaw();
      const uniq = getSelectedCodesUniquePreserveOrder(raw);

      document.getElementById('ServiceCodesHidden').value = uniq.join(',');
      document.getElementById('TitleHidden').value = computeTitleFromCodes(uniq);
    }

    function preventDuplicate(selectEl) {
      const val = (selectEl?.value || '').trim();
      if (!val) { setSvcMessage('', false); return; }

      const all = Array.from(document.querySelectorAll('.svc-dd'));
      const dupCount = all.filter(x => (x.value || '').trim().toLowerCase() === val.toLowerCase()).length;

      if (dupCount > 1) {
        selectEl.value = '';
        setSvcMessage('This service is already selected. Please choose a different service.', true);
      } else {
        setSvcMessage('', false);
      }
    }

    function addRow(selectedValue) {
      const row = document.createElement('div');
      row.className = 'svc-row';

      row.innerHTML =
        `<div style="flex:1;">${buildSelectHtml(selectedValue)}</div>` +
        `<button type="button" class="svc-remove-btn" title="Remove">×</button>`;

      document.getElementById('serviceRows').appendChild(row);

      const btnRemove = row.querySelector('.svc-remove-btn');
      const dd = row.querySelector('.svc-dd');

      btnRemove.addEventListener('click', function () {
        row.remove();
        setSvcMessage('', false);
        syncHidden();
      });

      dd.addEventListener('change', function () {
        preventDuplicate(dd);
        syncHidden();
      });

      syncHidden();
    }

    function clearServiceRows() {
      const box = document.getElementById('serviceRows');
      box.innerHTML = '';
      document.getElementById('ServiceCodesHidden').value = '';
    }

    function validateBeforeSubmit() {
      const uniq = getSelectedCodesUniquePreserveOrder(getSelectedCodesRaw());
      if (!uniq || uniq.length === 0) {
        setSvcMessage('Please select at least one service before saving.', true);
        return false;
      }
      setSvcMessage('', false);
      return true;
    }

    async function loadCustomerServices(customerCode) {
      const loading = document.getElementById('svcLoading');
      if (loading) loading.style.display = 'block';

      try {
        // Pass apptId for virtual calculation
        const apptId = document.getElementById('ApptId')?.value || '';
        let url = `/Appointment/GetCustomerServices?customerCode=${encodeURIComponent(customerCode)}`;
        if (apptId) url += `&apptId=${encodeURIComponent(apptId)}`;
        const res = await fetch(url, { method: 'GET' });
        const data = await res.json();

        if (!data || data.ok !== true) serviceItems = [];
        else serviceItems = data.items || [];
      } catch (e) {
        serviceItems = [];
      } finally {
        if (loading) loading.style.display = 'none';
      }
    }

    function buildRowsForEdit() {
      clearServiceRows();

      if (Array.isArray(preselected) && preselected.length > 0) {
        for (const c of preselected) addRow((c || '').trim());
      } else {
        addRow('');
      }

      syncHidden();
    }

    document.addEventListener('DOMContentLoaded', async function () {

      // init ApptStart hidden
      syncApptStartHidden();
      const apptDate = document.getElementById('ApptDate');
      const apptTime = document.getElementById('ApptTime');
      if (apptDate) apptDate.addEventListener('change', syncApptStartHidden);
      if (apptTime) apptTime.addEventListener('change', syncApptStartHidden);

      // Add service button
      document.getElementById('btnAddService').addEventListener('click', function () {
        addRow('');
      });

      const custDd = document.getElementById('CustomerCode');
      if (custDd) {
        // initial load for current selected customer
        const initialCust = (custDd.value || '').trim();
        if (initialCust) {
          await loadCustomerServices(initialCust);
        } else {
          serviceItems = [];
        }

        // build rows using preselected codes
        buildRowsForEdit();

        // on customer change -> reload services and reset rows
        custDd.addEventListener('change', async function () {
          const code = (custDd.value || '').trim();

          setSvcMessage('', false);

          if (!code) {
            serviceItems = [];
            clearServiceRows();
            addRow('');
            syncHidden();
            return;
          }

          await loadCustomerServices(code);

          // ✅ when customer changes, discard old preselected and start fresh
          clearServiceRows();
          addRow('');
          syncHidden();
        });
      } else {
        // fallback
        addRow('');
        syncHidden();
      }

      // submit validation
      const form = document.getElementById('apptForm');
      if (form) {
        form.addEventListener('submit', function (e) {
          syncApptStartHidden();
          syncHidden();

          if (!validateBeforeSubmit()) {
            e.preventDefault();
            e.stopPropagation();
            return false;
          }
        });
      }
    });
  </script>
}
