@model YourApp.Models.Appointment
@{
    ViewData["Title"] = "Delete Appointment";
}
<link rel="stylesheet" href="~/lib/bootstrap/bootstrap.min.css" />
<style>
    .delete-card {
        max-width: 420px;
        margin: 40px auto;
        box-shadow: 0 2px 16px rgba(0,0,0,0.10);
        border-radius: 12px;
        background: #fff;
        padding: 32px 28px 24px 28px;
    }
    .delete-card h2 {
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 18px;
        text-align: center;
    }
    .delete-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        margin-top: 18px;
    }
</style>
<div class="delete-card">
    <h2>Delete Appointment</h2>
    <p>Are you sure you want to delete this appointment?</p>
    <ul>
        <li><strong>Title:</strong> @Model.Title</li>
        <li><strong>Customer:</strong> @Model.CustomerCode</li>
        <li><strong>Agent:</strong> @Model.AgentCode</li>
        <li><strong>Start:</strong> @Model.ApptStart.ToString("yyyy-MM-dd HH:mm")</li>
    </ul>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="ApptId" />
        <div class="delete-actions">
            <button type="submit" class="btn btn-danger px-4">Delete</button>
            <a asp-controller="Calendar" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
    </form>
</div>
