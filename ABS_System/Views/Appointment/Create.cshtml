@model YourApp.Models.Appointment
@using System.Collections.Generic
@using System.Linq

@{
    var serviceItemsList = ViewBag.ServiceItems as List<YourApp.Models.ST_ITEM>
                           ?? new List<YourApp.Models.ST_ITEM>();
}

<h2>Create Appointment</h2>

<style>
  /* =========================
     Base form card
     ========================= */
  .booking-form {
    max-width: 420px;
    margin: 0 auto;
    background: #f8f9fa;
    border-radius: 12px;
    padding: 28px 24px 22px;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    border: 1px solid rgba(0,0,0,0.06);
  }

  /* Each form block spacing (Customer, Agent, Time, Services...) */
  .booking-form .field-block {
    margin-bottom: 16px;
  }

  .booking-form label {
    font-weight: 700;
    margin-bottom: 6px;
    display: block;
    color: #212529;
    font-size: 0.95rem;
  }

  /* Inputs / selects */
  .booking-form input,
  .booking-form select {
    width: 100%;
    padding: 9px 11px;
    border: 1px solid rgba(0,0,0,0.18);
    border-radius: 8px;
    font-size: 1rem;
    background: #fff;
    margin: 0; /* ✅ IMPORTANT: remove default margin so spacing is controlled by .field-block */
    outline: none;
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .booking-form input:focus,
  .booking-form select:focus {
    border-color: rgba(13,110,253,0.55);
    box-shadow: 0 0 0 0.18rem rgba(13,110,253,0.18);
  }

  /* =========================
     Validation summary
     ========================= */
  .validation-summary {
    background: #fff3f3;
    border: 1px solid #f5c2c7;
    color: #842029;
    border-radius: 10px;
    padding: 10px 12px;
    margin-bottom: 16px;
    font-size: 0.95em;
  }

  .validation-summary ul {
    margin: 0;
    padding-left: 18px;
  }

  /* =========================
     Services section
     ========================= */
  .svc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px; /* ✅ space between header and the box */
  }

  .svc-box {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 10px;
    padding: 12px;
  }

  /* gap between rows + top spacing inside box */
  #serviceRows {
    display: flex;
    flex-direction: column;
    gap: 10px;        /* ✅ spacing between each service row */
    margin-top: 2px;  /* ✅ small breathing space from top */
  }

  .svc-row {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  /* select inside row */
  .svc-row .svc-dd {
    height: 40px;
  }

  .svc-add-btn {
    padding: 7px 12px;
    border-radius: 9px;
    border: none;
    background: #198754;
    color: #fff;
    font-weight: 700;
    cursor: pointer;
    transition: filter 0.15s ease;
  }

  .svc-add-btn:hover { filter: brightness(0.95); }

  .svc-remove-btn {
    width: 44px;
    height: 40px;
    border-radius: 9px;
    border: none;
    background: #dc3545;
    color: #fff;
    font-weight: 900;
    cursor: pointer;
    transition: filter 0.15s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .svc-remove-btn:hover { filter: brightness(0.95); }

  .svc-hint {
    display: block;
    margin-top: 10px;
    font-size: 0.92em;
    color: #6c757d;
  }

  /* =========================
     Form action buttons
     ========================= */
  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }

  .form-actions button,
  .form-actions a {
    padding: 9px 18px;
    border-radius: 9px;
    border: none;
    font-size: 1em;
    text-decoration: none;
    color: #fff;
    background: #0d6efd;
    transition: filter 0.15s ease;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .form-actions a {
    background: #6c757d;
  }

  .form-actions button:hover,
  .form-actions a:hover {
    filter: brightness(0.95);
  }

  /* ✅ Extra gap between Appointment Time and Services */
.appt-time-block {
  margin-bottom: 26px !important;
}

</style>



<form asp-action="Create" method="post" class="booking-form">
  @Html.AntiForgeryToken()

  <div asp-validation-summary="All" class="validation-summary"></div>

  <!-- ✅ Hidden Title (auto-filled from ServiceCodes) -->
  <input type="hidden" asp-for="Title" id="TitleHidden" />

  <div>
    <label>Customer</label>
    <select asp-for="CustomerCode">
      <option value="">-- Select Customer --</option>
      @if (ViewBag.Customers != null)
      {
        foreach (var cust in (List<dynamic>)ViewBag.Customers)
        {
          var selected = Model.CustomerCode == cust.Code ? "selected" : null;
          <option value="@cust.Code" selected="@selected">@cust.Name</option>
        }
      }
    </select>
  </div>

  <div>
    <label>Agent</label>
    <select asp-for="AgentCode">
      <option value="">-- Select Agent --</option>
      @if (ViewBag.Agents != null)
      {
        foreach (var agent in (List<dynamic>)ViewBag.Agents)
        {
          var selected = Model.AgentCode == agent.Code ? "selected" : null;
          <option value="@agent.Code" selected="@selected">@agent.Description</option>
        }
      }
    </select>
  </div>

<!-- ✅ Split Date + Time (still submit ApptStart) -->
<div class="field-block appt-time-block">
  <label>Appointment Date</label>
  <input type="date" id="ApptDate"
         value="@Model.ApptStart.ToString("yyyy-MM-dd")" />

  <div style="height:12px;"></div>

  <label>Appointment Time</label>
  <input type="time" id="ApptTime"
         value="@Model.ApptStart.ToString("HH:mm")" />

  <!-- ✅ Hidden real field that is submitted to controller -->
  <input asp-for="ApptStart" type="datetime-local" id="ApptStartHidden" style="display:none;"
         value="@Model.ApptStart.ToString("yyyy-MM-ddTHH:mm")" />
</div>



  <!-- ✅ Services (dynamic rows) -->
  <div>
    <div class="svc-header">
      <label style="margin:0;">Services</label>
      <button type="button" id="btnAddService" class="svc-add-btn">+ Add</button>
    </div>

    <input type="hidden" name="ServiceCodes" id="ServiceCodesHidden" value="" />
    <div id="serviceRows"></div>

    <small class="svc-hint">Tip: Pick the services to include in this appointment.</small>
  </div>

  <div class="form-actions">
    <button type="submit">Save</button>
    <a asp-controller="Calendar" asp-action="Index">Cancel</a>
  </div>
</form>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />

  <script>
    const serviceItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
      serviceItemsList.Select(x => new { code = x.CODE, desc = x.DESCRIPTION }).ToList()
    ));

    function syncApptStartHidden() {
  const d = (document.getElementById('ApptDate')?.value || '').trim();
  const t = (document.getElementById('ApptTime')?.value || '').trim();

  const hidden = document.getElementById('ApptStartHidden');
  if (!hidden) return;

  // If either is missing, clear hidden so validation can catch it if you enforce required
  if (!d || !t) {
    hidden.value = '';
    return;
  }

  // datetime-local expects: YYYY-MM-DDTHH:mm
  hidden.value = `${d}T${t}`;
}


    function escHtml(s) {
      return (s || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function buildSelectHtml(selectedValue) {
      let html = `<select class="svc-dd">`;
      html += `<option value="">-- Select Service --</option>`;
      for (const it of serviceItems) {
        const code = (it.code || '').trim();
        const text = `${code} - ${(it.desc || '').trim()}`;
        const sel = (selectedValue && selectedValue === code) ? 'selected' : '';
        html += `<option value="${escHtml(code)}" ${sel}>${escHtml(text)}</option>`;
      }
      html += `</select>`;
      return html;
    }

    function computeTitleFromCodes(codes) {
      if (!codes || codes.length === 0) return '';
      const first = codes[0];
      return (codes.length > 1) ? (first + '...') : first;
    }

    function syncHidden() {
      const codes = Array.from(document.querySelectorAll('.svc-dd'))
        .map(x => (x.value || '').trim())
        .filter(x => x.length > 0);

      const uniq = [];
      const seen = {};
      for (const c of codes) {
        const k = c.toLowerCase();
        if (!seen[k]) {
          uniq.push(c);
          seen[k] = true;
        }
      }

      document.getElementById('ServiceCodesHidden').value = uniq.join(',');
      document.getElementById('TitleHidden').value = computeTitleFromCodes(uniq);
    }

    function addRow(selectedValue) {
      const row = document.createElement('div');
      row.className = 'svc-row';

      row.innerHTML =
        `<div style="flex:1;">${buildSelectHtml(selectedValue)}</div>` +
        `<button type="button" class="svc-remove-btn" title="Remove">×</button>`;

      document.getElementById('serviceRows').appendChild(row);

      row.querySelector('.svc-remove-btn').addEventListener('click', function () {
        row.remove();
        syncHidden();
      });

      row.querySelector('.svc-dd').addEventListener('change', function () {
        syncHidden();
      });

      syncHidden();
    }

    document.addEventListener('DOMContentLoaded', function () {
  addRow('');

  // ✅ init hidden datetime from split fields
  syncApptStartHidden();

  // ✅ keep hidden datetime updated live
  const apptDate = document.getElementById('ApptDate');
  const apptTime = document.getElementById('ApptTime');
  if (apptDate) apptDate.addEventListener('change', syncApptStartHidden);
  if (apptTime) apptTime.addEventListener('change', syncApptStartHidden);

  document.getElementById('btnAddService').addEventListener('click', function () {
    addRow('');
  });

  const form = document.querySelector('form.booking-form');
  if (form) {
    form.addEventListener('submit', function () {
      // ✅ ensure ApptStart is correct before submit
      syncApptStartHidden();

      // existing
      syncHidden();
    });
  }
});

  </script>
}
