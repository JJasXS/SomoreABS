@model YourApp.Models.Appointment
@using System.Collections.Generic
@using System.Linq

@{
    // NOTE: services will be loaded by AJAX now, so no need serviceItemsList
}

<center><h2>Create Appointment</h2></center>

<style>
.two-col{
  display:grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
@@media (max-width: 520px){
  .two-col{ grid-template-columns: 1fr; }
}

.dt-row{
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.dt-col label{
  margin-top: 0;
}

@@media (max-width: 520px){
  .dt-row{
    grid-template-columns: 1fr;
  }
}

.booking-form {
  max-width: 420px;
  margin: 0 auto;
  background: #f8f9fa;
  border-radius: 12px;
  padding: 28px 24px 22px;
  box-shadow: 0 6px 18px rgba(0,0,0,0.08);
  border: 1px solid rgba(0,0,0,0.06);
}

.booking-form .field-block { margin-bottom: 16px; }

.booking-form label {
  font-weight: 700;
  margin-bottom: 6px;
  display: block;
  color: #212529;
  font-size: 0.95rem;
}

.booking-form input,
.booking-form select {
  width: 100%;
  padding: 9px 11px;
  border: 1px solid rgba(0,0,0,0.18);
  border-radius: 8px;
  font-size: 1rem;
  background: #fff;
  margin: 0;
  outline: none;
  transition: box-shadow 0.15s ease, border-color 0.15s ease;
}

.booking-form input:focus,
.booking-form select:focus {
  border-color: rgba(13,110,253,0.55);
  box-shadow: 0 0 0 0.18rem rgba(13,110,253,0.18);
}

.validation-summary {
  background: #fff3f3;
  border: 1px solid #f5c2c7;
  color: #842029;
  border-radius: 10px;
  padding: 10px 12px;
  margin-bottom: 16px;
  font-size: 0.95em;
}

.validation-summary ul { margin: 0; padding-left: 18px; }

.svc-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-bottom: 10px;
}

#serviceRows{
  display:flex;
  flex-direction:column;
  gap:10px;
  margin-top:2px;
}

.svc-row{
  display:flex;
  gap:10px;
  align-items:center;
}

.svc-row .svc-dd{ height: 40px; }

.svc-add-btn{
  padding: 7px 12px;
  border-radius: 9px;
  border:none;
  background:#198754;
  color:#fff;
  font-weight:700;
  cursor:pointer;
  transition: filter 0.15s ease;
}

.svc-add-btn:hover{ filter: brightness(0.95); }

.svc-remove-btn{
  width:44px;
  height:40px;
  border-radius:9px;
  border:none;
  background:#dc3545;
  color:#fff;
  font-weight:900;
  cursor:pointer;
  transition: filter 0.15s ease;
  display:inline-flex;
  align-items:center;
  justify-content:center;
}

.svc-remove-btn:hover{ filter: brightness(0.95); }

.svc-hint{
  display:block;
  margin-top:10px;
  font-size:0.92em;
  color:#6c757d;
}

.form-actions{
  display:flex;
  gap:12px;
  margin-top:8px;
}

.form-actions button,
.form-actions a{
  padding: 9px 18px;
  border-radius: 9px;
  border:none;
  font-size:1em;
  text-decoration:none;
  color:#fff;
  background:#0d6efd;
  transition: filter 0.15s ease;
  cursor:pointer;
  display:inline-flex;
  align-items:center;
  justify-content:center;
}

.form-actions a{ background:#6c757d; }

.form-actions button:hover,
.form-actions a:hover{ filter: brightness(0.95); }

.appt-time-block{ margin-bottom: 26px !important; }

/* ✅ tiny helper text for loading */
.svc-loading{
  font-size: 0.92em;
  color: #0d6efd;
  margin: 6px 0 0;
  display: none;
}
</style>

<form asp-action="Create" method="post" class="booking-form">
  @Html.AntiForgeryToken()

  <div asp-validation-summary="All" class="validation-summary"></div>

  <input type="hidden" asp-for="Title" id="TitleHidden" />

  <div class="field-block two-col">
    <div>
      <label>Customer</label>
      <select asp-for="CustomerCode" id="CustomerCode">
        <option value="">-- Select Customer --</option>
        @if (ViewBag.Customers != null)
        {
          foreach (var cust in (List<dynamic>)ViewBag.Customers)
          {
            var selected = Model.CustomerCode == cust.Code ? "selected" : null;
            <option value="@cust.Code" selected="@selected">@cust.DisplayName</option>
          }
        }
      </select>
    </div>

    <div>
      <label>Agent</label>
      <select asp-for="AgentCode" id="AgentCode">
        <option value="">-- Select Agent --</option>
        @if (ViewBag.Agents != null)
        {
          foreach (var agent in (List<dynamic>)ViewBag.Agents)
          {
            var selected = Model.AgentCode == agent.Code ? "selected" : null;
            <option value="@agent.Code" selected="@selected">@agent.Description</option>
          }
        }
      </select>
    </div>
  </div>

  <div class="field-block appt-time-block">
    <div class="dt-row">
      <div class="dt-col">
        <label>Appointment Date</label>
        <input type="date" id="ApptDate" value="@Model.ApptStart.ToString("yyyy-MM-dd")" />
      </div>

      <div class="dt-col">
        <label>Appointment Time</label>
        <input type="time" id="ApptTime" value="@Model.ApptStart.ToString("HH:mm")" />
      </div>
    </div>

    <input asp-for="ApptStart" type="datetime-local" id="ApptStartHidden" style="display:none;"
           value="@Model.ApptStart.ToString("yyyy-MM-ddTHH:mm")" />
  </div>

  <div>
    <div class="svc-header">
      <label style="margin:0;">Services</label>
      <button type="button" id="btnAddService" class="svc-add-btn">+ Add</button>
    </div>

    <div class="svc-loading" id="svcLoading">Loading services for customer...</div>

    <input type="hidden" name="ServiceCodes" id="ServiceCodesHidden" value="" />
    <div id="serviceRows"></div>

    <small class="svc-hint">Tip: Select services purchased by this customer.</small>
  </div>

  <div class="form-actions">
    <button type="submit">Save</button>
    <a asp-controller="Calendar" asp-action="Index">Cancel</a>
  </div>
</form>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />

  <script>
    // ✅ will be replaced after customer selection
    let serviceItems = [];

    function syncApptStartHidden() {
      const d = (document.getElementById('ApptDate')?.value || '').trim();
      const t = (document.getElementById('ApptTime')?.value || '').trim();

      const hidden = document.getElementById('ApptStartHidden');
      if (!hidden) return;

      if (!d || !t) {
        hidden.value = '';
        return;
      }

      hidden.value = `${d}T${t}`;
    }

    function escHtml(s) {
      return (s || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function buildSelectHtml(selectedValue) {
      let html = `<select class="svc-dd">`;
      html += `<option value="">-- Select Service --</option>`;

      for (const it of serviceItems) {
        const code = (it.code || '').trim();
        let desc = (it.desc || '').trim();
        const balance = typeof it.balance === 'number' ? it.balance : null;
        let balanceHtml = '';
        if (balance !== null) {
          const color = balance > 0 ? 'green' : 'red';
          balanceHtml = `<span style='color:${color};font-weight:bold;'> (Balance: ${balance})</span>`;
        }
        let text = `${code} - ${escHtml(desc)}${balanceHtml}`;
        const sel = (selectedValue && selectedValue === code) ? 'selected' : '';
        // If description contains 'Last one!' flag, show warning
        if (desc.includes('(Last one!)')) {
          text = `${code} - <span style='color:red;font-weight:bold;'>${escHtml(desc)}</span>${balanceHtml}`;
        }
        html += `<option value="${escHtml(code)}" ${sel}>${text}</option>`;
      }

      html += `</select>`;
      return html;
    }

    function computeTitleFromCodes(codes) {
      if (!codes || codes.length === 0) return '';
      const first = codes[0];
      return (codes.length > 1) ? (first + '...') : first;
    }

    function syncHidden() {
      const codes = Array.from(document.querySelectorAll('.svc-dd'))
        .map(x => (x.value || '').trim())
        .filter(x => x.length > 0);

      const uniq = [];
      const seen = {};
      for (const c of codes) {
        const k = c.toLowerCase();
        if (!seen[k]) {
          uniq.push(c);
          seen[k] = true;
        }
      }

      document.getElementById('ServiceCodesHidden').value = uniq.join(',');
      document.getElementById('TitleHidden').value = computeTitleFromCodes(uniq);
    }

    function addRow(selectedValue) {
      const row = document.createElement('div');
      row.className = 'svc-row';

      row.innerHTML =
        `<div style="flex:1;">${buildSelectHtml(selectedValue)}</div>` +
        `<button type="button" class="svc-remove-btn" title="Remove">×</button>`;

      document.getElementById('serviceRows').appendChild(row);

      row.querySelector('.svc-remove-btn').addEventListener('click', function () {
        row.remove();
        syncHidden();
      });

      row.querySelector('.svc-dd').addEventListener('change', function () {
        syncHidden();
      });

      syncHidden();
    }

    function clearServiceRows() {
      const box = document.getElementById('serviceRows');
      box.innerHTML = '';
      document.getElementById('ServiceCodesHidden').value = '';
      document.getElementById('TitleHidden').value = '';
    }

    async function loadCustomerServices(customerCode) {
      const loading = document.getElementById('svcLoading');
      if (loading) loading.style.display = 'block';

      try {
        const url = `/Appointment/GetCustomerServices?customerCode=${encodeURIComponent(customerCode)}`;
        const res = await fetch(url, { method: 'GET' });
        const data = await res.json();

        if (!data || data.ok !== true) {
          serviceItems = [];
        } else {
          serviceItems = data.items || [];
        }
      } catch (e) {
        serviceItems = [];
      } finally {
        if (loading) loading.style.display = 'none';
      }

      // rebuild UI
      clearServiceRows();
      addRow('');
    }

    document.addEventListener('DOMContentLoaded', function () {
      // start
      syncApptStartHidden();

      const apptDate = document.getElementById('ApptDate');
      const apptTime = document.getElementById('ApptTime');
      if (apptDate) apptDate.addEventListener('change', syncApptStartHidden);
      if (apptTime) apptTime.addEventListener('change', syncApptStartHidden);

      // service add button
      document.getElementById('btnAddService').addEventListener('click', function () {
        addRow('');
      });

      // customer change -> load services
      const custDd = document.getElementById('CustomerCode');
      if (custDd) {
        custDd.addEventListener('change', function () {
          const code = (custDd.value || '').trim();
          if (!code) {
            serviceItems = [];
            clearServiceRows();
            addRow('');
            return;
          }
          loadCustomerServices(code);
        });

        // ✅ if customer already selected (edit/back-validation case), auto-load
        const initialCust = (custDd.value || '').trim();
        if (initialCust) {
          loadCustomerServices(initialCust);
        } else {
          addRow(''); // empty initial
        }
      } else {
        addRow('');
      }

      const form = document.querySelector('form.booking-form');
      if (form) {
        form.addEventListener('submit', function () {
          syncApptStartHidden();
          syncHidden();
        });
      }
    });
  </script>
}
